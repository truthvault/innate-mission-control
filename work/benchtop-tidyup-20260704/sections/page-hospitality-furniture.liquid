  .hosp-size li:first-child { border-top-color: rgba(22,37,31,0.13); }
  .hosp-size strong { display: block; color: var(--hosp-ink); font-weight: 700; letter-spacing: -0.01em; }
  .hosp-size span { display: block; margin-top: 2px; color: var(--innate-rust); }
  .hosp-materials { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; align-items: stretch; }
  .hosp-material { position: relative; min-height: 100%; padding: 26px 24px 25px; border: 1px solid rgba(251,247,239,0.28); background: linear-gradient(180deg, rgba(251,247,239,0.13), rgba(251,247,239,0.075)); box-shadow: inset 0 1px 0 rgba(251,247,239,0.08), 0 18px 42px rgba(4,11,8,0.16); }
  .hosp-material::before { content: ""; display: block; width: 44px; height: 4px; margin-bottom: 20px; border-radius: 999px; background: rgba(251,247,239,0.58); box-shadow: 0 0 0 1px rgba(251,247,239,0.08); }
  .hosp-material--timber::before { background: #9a5f35; }
