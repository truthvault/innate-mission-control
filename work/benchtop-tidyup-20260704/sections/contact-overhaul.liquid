<section class="contact-overhaul" data-contact-overhaul>
  {{ 'innate-contact-overhaul.css' | asset_url | stylesheet_tag }}

  {%- liquid
    assign people_primary_asset = section.settings.people_image_asset | strip
    assign people_secondary_asset = section.settings.people_secondary_image_asset | strip
    assign has_people_primary = false
    assign has_people_secondary = false

    if section.settings.people_image != blank or people_primary_asset != blank
      assign has_people_primary = true
    endif

    if section.settings.people_secondary_image != blank or people_secondary_asset != blank
      assign has_people_secondary = true
    endif
  -%}

  <div class="contact-overhaul__hero">
    <div class="contact-overhaul__inner">
      <div class="contact-overhaul__hero-grid">
        <div class="contact-overhaul__hero-copy">
          {%- if section.settings.eyebrow != blank -%}
            <p class="contact-overhaul__eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          <h1 class="contact-overhaul__title">{{ section.settings.heading }}</h1>
          {%- if section.settings.intro != blank -%}
            <div class="contact-overhaul__intro">{{ section.settings.intro }}</div>
          {%- endif -%}
          <div class="contact-overhaul__hero-actions">
            <a class="contact-overhaul__button" href="#message">{{ section.settings.primary_action_label }}</a>
            <a class="contact-overhaul__button contact-overhaul__button--secondary" href="#visit">{{ section.settings.secondary_action_label }}</a>
          </div>
        </div>
        {%- if has_people_primary or has_people_secondary -%}
          <aside class="contact-overhaul__hero-people" aria-label="{{ section.settings.people_eyebrow | escape }}">
            <div class="contact-overhaul__portrait-grid{% unless has_people_secondary %} contact-overhaul__portrait-grid--single{% endunless %}">
              {%- if has_people_primary -%}
                <figure class="contact-overhaul__portrait">
                  {%- if people_primary_asset != blank -%}
                    <img src="{{ people_primary_asset | asset_url }}" alt="{{ section.settings.people_image_alt | escape }}" width="900" height="1124" loading="eager">
                  {%- else -%}
                    {{ section.settings.people_image | image_url: width: 1000 | image_tag: loading: 'eager', sizes: '(min-width: 980px) 17vw, 50vw', widths: '320, 480, 640, 800, 1000', alt: section.settings.people_image_alt }}
                  {%- endif -%}
                </figure>
              {%- endif -%}

              {%- if has_people_secondary -%}
                <figure class="contact-overhaul__portrait">
                  {%- if people_secondary_asset != blank -%}
                    <img src="{{ people_secondary_asset | asset_url }}" alt="{{ section.settings.people_secondary_image_alt | escape }}" width="900" height="1352" loading="eager">
                  {%- else -%}
                    {{ section.settings.people_secondary_image | image_url: width: 1000 | image_tag: loading: 'eager', sizes: '(min-width: 980px) 17vw, 50vw', widths: '320, 480, 640, 800, 1000', alt: section.settings.people_secondary_image_alt }}
                  {%- endif -%}
                </figure>
              {%- endif -%}
            </div>
            <div class="contact-overhaul__hero-people-copy">
              <p class="contact-overhaul__label">{{ section.settings.people_eyebrow }}</p>
              {%- if section.settings.people_heading != blank -%}
                <h2>{{ section.settings.people_heading }}</h2>
              {%- endif -%}
              <div>{{ section.settings.people_text }}</div>
            </div>
          </aside>
        {%- endif -%}
      </div>

      <aside class="contact-overhaul__direct" aria-label="Direct contact details">
        <div class="contact-overhaul__direct-heading">
          <p class="contact-overhaul__label">{{ section.settings.direct_eyebrow }}</p>
          <h2>{{ section.settings.direct_heading }}</h2>
        </div>
        <div class="contact-overhaul__direct-list">
          <a class="contact-overhaul__direct-link" href="tel:{{ section.settings.phone_href }}">
            <span>{{ section.settings.phone_label }}</span>
            <span>{{ section.settings.phone_display }}</span>
          </a>
          <a class="contact-overhaul__direct-link" href="mailto:{{ section.settings.email }}">
            <span>{{ section.settings.email_label }}</span>
            <span>{{ section.settings.email }}</span>
          </a>
          <a class="contact-overhaul__direct-link" href="#visit">
            <span>{{ section.settings.visit_label }}</span>
            <span>{{ section.settings.visit_display }}</span>
          </a>
        </div>
        {%- if section.settings.direct_note != blank -%}
          <p class="contact-overhaul__direct-note">{{ section.settings.direct_note }}</p>
        {%- endif -%}
      </aside>

      <div class="contact-overhaul__sample-callout">
        <div>
          <p class="contact-overhaul__label">{{ section.settings.sample_eyebrow }}</p>
          <h2>{{ section.settings.sample_heading }}</h2>
        </div>
        <p>{{ section.settings.sample_text }}</p>
        <a class="contact-overhaul__text-link" href="{{ section.settings.sample_link }}">{{ section.settings.sample_link_label }}</a>
      </div>
    </div>
  </div>

  <div class="contact-overhaul__nav">
    <div class="contact-overhaul__inner">
      <div class="contact-overhaul__nav-head">
        <h2 class="contact-overhaul__section-title">{{ section.settings.routes_heading }}</h2>
        <p>{{ section.settings.routes_text }}</p>
      </div>
      <div class="contact-overhaul__cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'route' -%}
            <a class="contact-overhaul__card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
              <strong>{{ block.settings.title }}</strong>
              <span>{{ block.settings.text }}</span>
              <em>{{ block.settings.action }}</em>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div id="visit" class="contact-overhaul__visit">
    <div class="contact-overhaul__inner contact-overhaul__visit-grid">
      <div class="contact-overhaul__visit-copy">
        <p class="contact-overhaul__label">{{ section.settings.visit_eyebrow }}</p>
        <h2 class="contact-overhaul__section-title">{{ section.settings.visit_heading }}</h2>
        <div>{{ section.settings.visit_text }}</div>
      </div>
      <div class="contact-overhaul__map-panel" data-contact-map-loader="{{ section.id }}">
        <p class="contact-overhaul__map-title">{{ section.settings.map_title }}</p>
        <p class="contact-overhaul__map-address">{{ section.settings.map_address }}</p>
        <div class="contact-overhaul__map-actions">
          <button type="button" class="contact-overhaul__map-button" data-contact-map-load>{{ section.settings.map_load_label }}</button>
          <a class="contact-overhaul__map-link" href="{{ section.settings.map_link }}" target="_blank" rel="noopener">{{ section.settings.map_link_label }}</a>
        </div>
        <div class="contact-overhaul__map-frame" hidden>
          <iframe data-src="{{ section.settings.map_embed_url }}" title="{{ section.settings.map_iframe_title | escape }}" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
      {%- if section.settings.booking_enabled -%}
        <div class="contact-overhaul__booking-wrap">
          <script src="https://embed.ycb.me" async="true" data-domain="{{ section.settings.booking_domain }}" data-content="all"></script>
        </div>
      {%- endif -%}
    </div>
  </div>

  <div id="message" class="contact-overhaul__form-section">
    <div class="contact-overhaul__inner contact-overhaul__form-grid">
      <div class="contact-overhaul__form-copy">
        <p class="contact-overhaul__label">{{ section.settings.form_eyebrow }}</p>
        <h2 class="contact-overhaul__form-title">{{ section.settings.form_heading }}</h2>
        <div>{{ section.settings.form_intro }}</div>
        <ul class="contact-overhaul__hint-list">
          <li>{{ section.settings.form_hint_1 }}</li>
          <li>{{ section.settings.form_hint_2 }}</li>
          <li>{{ section.settings.form_hint_3 }}</li>
        </ul>
      </div>

      <div class="contact-overhaul__form">
        {% form 'contact' %}
          {%- if form.posted_successfully? -%}
            <div class="contact-overhaul__form-success" role="status">{{ section.settings.form_success }}</div>
          {%- else -%}
            {%- if form.errors -%}
              <div class="contact-overhaul__form-errors" role="alert">{{ form.errors | default_errors }}</div>
            {%- endif -%}
            <input type="hidden" name="contact[Subject]" value="{{ section.settings.form_subject }}">
            <div class="contact-overhaul__field contact-overhaul__field--half">
              <label for="contactOverhaulName">{{ section.settings.name_label }}</label>
              <input id="contactOverhaulName" type="text" name="contact[name]" autocomplete="name" required value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
            </div>
            <div class="contact-overhaul__field contact-overhaul__field--half">
              <label for="contactOverhaulEmail">{{ section.settings.email_field_label }}</label>
              <input id="contactOverhaulEmail" type="email" name="contact[email]" autocomplete="email" required value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
            </div>
            <div class="contact-overhaul__field contact-overhaul__field--half">
              <label for="contactOverhaulPhone">{{ section.settings.phone_field_label }}</label>
              <input id="contactOverhaulPhone" type="tel" name="contact[phone]" autocomplete="tel" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}">
            </div>
            <div class="contact-overhaul__field contact-overhaul__field--half">
              <label for="contactOverhaulInterest">{{ section.settings.interest_label }}</label>
              <select id="contactOverhaulInterest" name="contact[Interested in]">
                <option value="">{{ section.settings.interest_placeholder }}</option>
                <option>{{ section.settings.interest_option_1 }}</option>
                <option>{{ section.settings.interest_option_2 }}</option>
                <option>{{ section.settings.interest_option_3 }}</option>
                <option>{{ section.settings.interest_option_4 }}</option>
                <option>{{ section.settings.interest_option_5 }}</option>
              </select>
            </div>
            <div class="contact-overhaul__field contact-overhaul__field--half">
              <label for="contactOverhaulLocation">{{ section.settings.location_label }}</label>
              <input id="contactOverhaulLocation" type="text" name="contact[Location]" placeholder="{{ section.settings.location_placeholder }}">
            </div>
            <div class="contact-overhaul__field contact-overhaul__field--half">
              <label for="contactOverhaulTiming">{{ section.settings.timing_label }}</label>
              <input id="contactOverhaulTiming" type="text" name="contact[Timing]" placeholder="{{ section.settings.timing_placeholder }}">
            </div>
            <div class="contact-overhaul__field contact-overhaul__wide">
              <label for="contactOverhaulMessage">{{ section.settings.message_label }}</label>
              <textarea id="contactOverhaulMessage" name="contact[body]" placeholder="{{ section.settings.message_placeholder }}" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
            </div>
            <div class="contact-overhaul__form-actions">
              <button class="contact-overhaul__button" type="submit">{{ section.settings.button_label }}</button>
            </div>
          {%- endif -%}
        {% endform %}
      </div>
    </div>
  </div>

  {%- if section.settings.supplier_note != blank -%}
    <div class="contact-overhaul__supplier">
      <div class="contact-overhaul__inner">{{ section.settings.supplier_note }}</div>
    </div>
  {%- endif -%}
</section>

<script>
  (function() {
    var root = document.querySelector('[data-contact-map-loader="{{ section.id }}"]');
    if (!root) return;
    var button = root.querySelector('[data-contact-map-load]');
    var frame = root.querySelector('.contact-overhaul__map-frame');
    var iframe = root.querySelector('iframe[data-src]');
    if (!button || !frame || !iframe) return;
    button.addEventListener('click', function() {
      iframe.src = iframe.getAttribute('data-src');
      frame.hidden = false;
      button.hidden = true;
    });
  }());
</script>

