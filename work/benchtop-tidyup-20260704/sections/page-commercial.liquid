<style>
  .template-sufix-commerical .layout,
  .template-sufix-commerical #MainContent,
  .template-sufix-commerical .main { padding: 0; max-width: none; }
  .template-sufix-commerical main,
  .template-sufix-commerical [role=main] { background: var(--innate-paper); }
  .template-sufix-commerical .shopify-section + .shopify-section { margin: 0; }

  .commercial-page-v2 {
    --cp-cream: var(--innate-paper);
    --cp-paper: var(--innate-cream);
    --cp-panel: var(--innate-warm-white);
    --cp-ink: var(--innate-forest-ink);
    --cp-forest: var(--innate-forest);
    --cp-fern: var(--innate-moss);
    --cp-muted: rgba(19,35,29,.68);
    --cp-line: rgba(19,35,29,.13);
    --cp-brass: var(--innate-rust);
    --cp-display: var(--innate-display);
    --cp-body: var(--bench-body, 'Maven Pro', sans-serif);
    background: var(--cp-cream);
    color: var(--cp-ink);
    font-family: var(--cp-body);
  }
  .cp-section { padding: clamp(3.25rem, 6.2vw, 6.25rem) clamp(1.2rem, 4vw, 4rem); }
  .cp-section--tight { padding-top: clamp(2.5rem, 5vw, 4rem); padding-bottom: clamp(2.5rem, 5vw, 4rem); }
  .cp-wrap { max-width: 1180px; margin: 0 auto; }
  .cp-kicker { margin: 0 0 .85rem; font: 700 .76rem/1 var(--cp-body); letter-spacing: .14em; text-transform: uppercase; color: var(--innate-rust); }
  .cp-heading { margin: 0; font-family: var(--cp-display); font-size: clamp(2.05rem, 4.4vw, 4.2rem); line-height: 1.02; letter-spacing: 0; font-weight: 600; color: var(--cp-ink); }
  .cp-heading--mid { font-size: clamp(1.9rem, 3.4vw, 3.35rem); max-width: 760px; }
  .cp-lead { max-width: 58ch; margin: 1rem 0 0; font: 400 clamp(1rem, 1.2vw, 1.13rem)/1.66 var(--cp-body); color: var(--cp-muted); }
  .cp-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 48px; padding: .95rem 1.35rem; border-radius: 2px; font: 700 .96rem/1 var(--cp-body); text-decoration: none; transition: opacity .2s ease, border-color .2s ease, box-shadow .2s ease; }
  .cp-btn:hover { opacity: .82; }
  .cp-btn:focus-visible { outline: 0; box-shadow: 0 0 0 3px rgba(19,35,29,.22); }
  .cp-btn--primary { background: var(--cp-forest); color: var(--cp-cream); }
  .cp-btn--secondary { color: var(--cp-ink); border: 0; background: transparent; padding-left: .2rem; padding-right: .2rem; text-decoration: underline; text-underline-offset: .28em; }

  .cp-hero { padding: clamp(3.5rem, 6.5vw, 6.2rem) clamp(1.2rem, 4vw, 4rem) clamp(3rem, 5.8vw, 5rem); }
  .cp-hero__grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: minmax(0, .88fr) minmax(360px, 1.12fr); gap: clamp(2.4rem, 5vw, 5.5rem); align-items: center; }
  .cp-hero__copy { max-width: 590px; }
  .cp-hero__title { margin: 0; font-family: var(--cp-display); font-size: clamp(2.35rem, 4.1vw, 4.2rem); line-height: 1.02; letter-spacing: 0; font-weight: 600; color: var(--cp-ink); }
  .cp-hero__text { max-width: 55ch; margin: 1.05rem 0 0; font: 400 clamp(1rem, 1.22vw, 1.12rem)/1.65 var(--cp-body); color: rgba(19,35,29,.72); }
  .cp-hero__actions { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 1.55rem; }
  .cp-hero__trust { margin: 1.3rem 0 0; font: 700 .78rem/1.45 var(--cp-body); letter-spacing: .1em; text-transform: uppercase; color: rgba(19,35,29, .72); }
  .cp-hero__media { margin: 0; aspect-ratio: 1.12 / 1; overflow: hidden; background: rgba(19,35,29,.08); }
  .cp-img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* commercial-proof-outbound-2026-05-20 */
  .cp-proof-strip { padding: clamp(1.55rem, 3vw, 2.2rem) clamp(1.2rem, 4vw, 4rem); background: var(--cp-paper); border-top: 1px solid var(--cp-line); border-bottom: 1px solid var(--cp-line); }
  .cp-proof-strip__grid { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: minmax(240px, .46fr) minmax(0, 1fr); gap: clamp(1.5rem, 4vw, 3.5rem); align-items: start; }
  .cp-proof-strip__title { margin: 0; font: 600 clamp(1.35rem, 2vw, 1.9rem)/1.12 var(--cp-display); letter-spacing: 0; color: var(--cp-ink); }
  .cp-proof-strip__text { margin: .55rem 0 0; max-width: 38ch; font: 400 .96rem/1.55 var(--cp-body); color: var(--cp-muted); }
  .cp-proof-strip__names { display: flex; flex-wrap: wrap; gap: .55rem; margin: 0; padding: 0; list-style: none; }
  .cp-proof-strip__names li { border: 1px solid rgba(19,35,29,.16); background: rgba(255,250,243,.62); padding: .55rem .72rem; font: 700 .82rem/1 var(--cp-body); letter-spacing: .035em; text-transform: uppercase; color: rgba(19,35,29,.72); }
  .cp-proof-strip__note { margin: 1rem 0 0; font: 400 .92rem/1.55 var(--cp-body); color: rgba(19,35,29, .72); }
  .cp-proof-strip__note strong { color: var(--cp-ink); font-weight: 600; }
  /* commercial-project-cards-2026-05-20 */
  .cp-proof-projects { margin-top: clamp(1.2rem, 3vw, 2rem); display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .9rem; }
  .cp-proof-project { border: 1px solid rgba(19,35,29,.12); background: var(--cp-panel); display: flex; flex-direction: column; min-width: 0; }
  .cp-proof-project__media { margin: 0; aspect-ratio: 1.26 / .88; overflow: hidden; background: rgba(19,35,29,.08); }
  .cp-proof-project__body { padding: .95rem; }
  .cp-proof-project__meta { margin: 0 0 .35rem; font: 700 .72rem/1.2 var(--cp-body); letter-spacing: .07em; text-transform: uppercase; color: rgba(19,35,29, .72); }
  .cp-proof-project h3 { margin: 0; font: 600 1.1rem/1.18 var(--cp-display); letter-spacing: 0; color: var(--cp-ink); }
  .cp-proof-project__body p:last-child { margin: .45rem 0 0; font: 400 .9rem/1.45 var(--cp-body); color: rgba(19,35,29,.72); }
  .cp-proof-strip__coming { margin: .9rem 0 0; font: 400 .88rem/1.45 var(--cp-body); color: rgba(19,35,29, .72); }
  .cp-proof-cta { margin-top: 1.15rem; padding: 1rem 1.15rem; border: 1px solid rgba(19,35,29,.12); background: var(--cp-panel); display: flex; gap: 1rem; align-items: center; justify-content: space-between; flex-wrap: wrap; }
  .cp-proof-cta p { margin: 0; flex: 1 1 360px; font: 400 .94rem/1.5 var(--cp-body); color: rgba(19,35,29,.72); }
  .cp-proof-cta a { flex: 0 0 auto; padding: .82rem 1rem; background: var(--cp-forest); color: var(--cp-cream); text-decoration: none; font: 600 .9rem/1 var(--cp-body); }
  .cp-work-card--text-only .cp-work-card__body { min-height: 100%; padding: clamp(1.25rem, 2.8vw, 1.8rem); }
  .cp-advantage__grid--text-only { grid-template-columns: minmax(0, 760px); justify-content: center; }

  .cp-pathways { display: grid; grid-template-columns: minmax(0, 1.08fr) minmax(280px, .92fr); gap: 1rem; margin-top: clamp(2.5rem, 5vw, 4rem); }
  .cp-pathways__side { display: grid; gap: 1rem; }
  .cp-pathway { position: relative; display: flex; min-height: 250px; overflow: hidden; color: var(--cp-cream); text-decoration: none; background: var(--cp-forest); }
  .cp-pathway--large { min-height: 400px; }
  .cp-pathway__media { position: absolute; inset: 0; margin: 0; }
  .cp-pathway__media::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(19,35,29,.08), rgba(19,35,29,.82)); }
  .cp-pathway__media img { filter: saturate(.95); }
  .cp-pathway__body { position: relative; z-index: 1; align-self: flex-end; padding: clamp(1.25rem, 2.8vw, 2rem); max-width: 560px; }
  .cp-pathway__body h3 { margin: 0; font: 600 clamp(1.7rem, 2.6vw, 2.75rem)/1.04 var(--cp-display); letter-spacing: 0; color: var(--cp-cream); }
  .cp-pathway__body p { margin: .65rem 0 0; font: 400 .98rem/1.55 var(--cp-body); color: rgba(251,248,242,.8); }
  .cp-pathway__body span { display: inline-block; margin-top: 1rem; font: 600 .9rem/1 var(--cp-body); color: var(--cp-cream); text-decoration: underline; text-underline-offset: .28em; }

  .cp-problem { background: var(--cp-ink); color: var(--cp-cream); }
  .cp-problem .cp-kicker, .cp-problem .cp-heading { color: var(--cp-cream); }
  .cp-problem .cp-lead { color: rgba(251,248,242,.72); }
  .cp-problem__grid { display: grid; grid-template-columns: minmax(0, .95fr) minmax(360px, 1.05fr); gap: clamp(2rem, 6vw, 5rem); align-items: start; }
  .cp-problem__list { margin: .4rem 0 0; border-top: 1px solid rgba(251,248,242,.18); }
  .cp-problem__item { display: grid; grid-template-columns: 48px 1fr; gap: 1rem; padding: 1.15rem 0; border-bottom: 1px solid rgba(251,248,242,.18); }
  .cp-problem__num { font: 600 .78rem/1.5 var(--cp-body); letter-spacing: .12em; color: rgba(251,248,242,.44); }
  .cp-problem__item strong { display: block; font: 500 clamp(1.05rem, 1.4vw, 1.25rem)/1.25 var(--cp-body); color: var(--cp-cream); }
  .cp-problem__item span { display: block; margin-top: .35rem; font: 400 .95rem/1.55 var(--cp-body); color: rgba(251,248,242,.68); }

  .cp-work-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: clamp(1rem, 2.5vw, 1.6rem); margin-top: clamp(2rem, 4vw, 3rem); }
  .cp-selected-work { padding-top: clamp(3rem, 5.8vw, 5.8rem); }
  .cp-work-card { background: var(--cp-panel); border: 1px solid var(--cp-line); }
  .cp-work-card__media { margin: 0; aspect-ratio: 1.22 / 1; overflow: hidden; background: rgba(19,35,29,.07); }
  .cp-work-card__body { padding: 1.1rem; }
  .cp-work-card__meta { margin: 0 0 .45rem; font: 700 .72rem/1.2 var(--cp-body); letter-spacing: .11em; text-transform: uppercase; color: rgba(19,35,29, .72); }
  .cp-work-card h3 { margin: 0; font: 600 clamp(1.2rem,1.6vw,1.55rem)/1.1 var(--cp-display); letter-spacing: 0; color: var(--cp-ink); }
  .cp-work-card p { margin: .65rem 0 0; font: 400 .94rem/1.55 var(--cp-body); color: var(--cp-muted); }

  .cp-advantage__grid { display: grid; grid-template-columns: minmax(340px, .92fr) minmax(0, 1.08fr); gap: clamp(2rem, 5vw, 5rem); align-items: center; }
  .cp-advantage__media { margin: 0; aspect-ratio: 1 / .86; overflow: hidden; background: rgba(19,35,29,.07); }
  .cp-bullets { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem 1.2rem; margin: 1.6rem 0 0; padding: 0; list-style: none; }
  .cp-bullets li { border-top: 1px solid var(--cp-line); padding-top: .75rem; font: 600 .95rem/1.45 var(--cp-body); color: rgba(19,35,29,.78); }

  .cp-timeline { margin-top: 2rem; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); border-top: 1px solid var(--cp-line); border-bottom: 1px solid var(--cp-line); }
  .cp-step { padding: 1.25rem 1rem 1.25rem 0; border-right: 1px solid var(--cp-line); }
  .cp-step:last-child { border-right: 0; }
  .cp-step span { display: block; margin-bottom: .8rem; font: 700 .76rem/1 var(--cp-body); letter-spacing: .13em; color: rgba(19,35,29, .72); }
  .cp-step h3 { margin: 0; font: 500 clamp(1.05rem,1.3vw,1.22rem)/1.2 var(--cp-body); color: var(--cp-ink); }
  .cp-step p { margin: .45rem 0 0; font: 400 .9rem/1.5 var(--cp-body); color: var(--cp-muted); }

  .cp-materials { background: var(--cp-paper); border-top: 1px solid var(--cp-line); border-bottom: 1px solid var(--cp-line); }
  .cp-materials__row { display: grid; grid-template-columns: minmax(0, .72fr) minmax(0, 1fr); gap: clamp(1.5rem, 4vw, 4rem); align-items: center; }
  .cp-material-tags { display: flex; flex-wrap: wrap; gap: .6rem; margin-top: 1.4rem; }
  .cp-material-tags span { border: 1px solid var(--cp-line); padding: .55rem .75rem; font: 600 .88rem/1 var(--cp-body); color: rgba(19,35,29,.72); background: rgba(255,250,243,.62); }

  .cp-form-section { background: var(--cp-ink); color: var(--cp-cream); }
  .cp-form-section .cp-kicker, .cp-form-section .cp-heading { color: var(--cp-cream); }
  .cp-form-section .cp-lead { color: rgba(251,248,242,.72); }
  .cp-form-grid { display: grid; grid-template-columns: minmax(0, .72fr) minmax(0, 1fr); gap: clamp(2rem, 5vw, 5rem); align-items: start; }
  .cp-form-section form { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
  .cp-form-section textarea, .cp-form-wide, .cp-form-section button[type="submit"], .cp-form-errors, .cp-form-success { grid-column: 1 / -1; }
  .cp-form-section input[type="text"], .cp-form-section input[type="email"], .cp-form-section input[type="tel"], .cp-form-section textarea, .cp-form-section select { width: 100%; box-sizing: border-box; padding: .9rem 1rem; background: rgba(255,250,243,.12); border: 1px solid rgba(255,250,243,.42); color: var(--cp-cream); font: 400 1rem/1.45 var(--cp-body); border-radius: 2px; box-shadow: inset 0 1px 0 rgba(255,250,243,.08); transition: background .2s ease, border-color .2s ease, box-shadow .2s ease; }
  .cp-form-section select option { color: var(--innate-forest-ink); }
  .cp-form-section input::placeholder, .cp-form-section textarea::placeholder { color: rgba(251,248,242,.68); }
  .cp-form-section input:focus-visible, .cp-form-section textarea:focus-visible, .cp-form-section select:focus-visible { outline: 0; background: rgba(255,250,243,.16); border-color: rgba(255,250,243,.82); box-shadow: 0 0 0 3px rgba(255,250,243,.2), inset 0 1px 0 rgba(255,250,243,.12); }
  .cp-form-section textarea { min-height: 140px; resize: vertical; }
  .cp-form-help { grid-column: 1 / -1; max-width: 720px; margin: -.05rem 0 .35rem; font: 400 .9rem/1.45 var(--cp-body); color: rgba(251,248,242,.68); }
  .cp-form-section button[type="submit"] { width: fit-content; margin-top: .15rem; padding: 1rem 1.75rem; border: 0; border-radius: 2px; background: var(--cp-cream); color: var(--cp-ink); font: 600 1rem/1 var(--cp-body); cursor: pointer; transition: background .2s ease, box-shadow .2s ease; }
  .cp-form-section button[type="submit"]:hover { background: var(--innate-warm-white); }
  .cp-form-section button[type="submit"]:focus-visible { outline: 0; box-shadow: 0 0 0 3px rgba(255,250,243,.28); }
  .cp-form-success { margin: 0; font: 400 clamp(1.6rem,3vw,2.2rem)/1.2 var(--cp-display); color: var(--cp-cream); }
  .cp-form-errors { padding: .85rem 1rem; background: rgba(160,40,40,.3); color: var(--cp-cream); }

  .cp-reviews-slot {
    background: var(--cp-cream);
    padding: clamp(18px, 2vw, 28px) 0 clamp(34px, 4vw, 56px);
  }
  .cp-reviews-slot .shopify-section.apps,
  .template-sufix-commerical .shopify-section.apps {
    background: transparent !important;
    overflow: hidden;
    padding: 0 clamp(16px, 4vw, 52px) !important;
  }
  .template-sufix-commerical .shopify-section.apps .grp-entangle--root {
    margin-left: auto !important;
    margin-right: auto !important;
    max-width: 1320px !important;
  }
  .template-sufix-commerical .shopify-section.apps .grp-entangle-swipper-badge-wrapper {
    align-items: flex-start !important;
  }
  .template-sufix-commerical .shopify-section.apps .grp-entangle-rating-container {
    align-items: center !important;
    align-self: flex-start !important;
    background: var(--cp-panel) !important;
    border: 1px solid rgba(19, 35, 29, .10) !important;
    border-radius: 18px !important;
    box-shadow: none !important;
    display: flex !important;
    justify-content: center !important;
    margin: 0 !important;
    min-height: 165px !important;
    min-width: clamp(270px, 20vw, 300px) !important;
    padding: 1.1rem 1.25rem !important;
    width: clamp(270px, 20vw, 300px) !important;
  }
  .template-sufix-commerical .shopify-section.apps .grp-entangle-item {
    background: var(--cp-panel) !important;
    border: 1px solid rgba(19, 35, 29, .08) !important;
    box-shadow: none !important;
  }
  .template-sufix-commerical .shopify-section.apps .grp-entangle-badge,
  .template-sufix-commerical .shopify-section.apps .grp-entangle-head-badge,
  .template-sufix-commerical .shopify-section.apps .grp-entangle-badge-flex,
  .template-sufix-commerical .shopify-section.apps .grp-entangle-badge-vertical {
    align-items: center !important;
    display: flex !important;
    flex-direction: column !important;
    gap: .45rem !important;
    height: auto !important;
    justify-content: center !important;
    text-align: center !important;
    width: 100% !important;
  }
  .template-sufix-commerical .shopify-section.apps .grp-entangle-badge-title {
    font-size: 0 !important;
    line-height: 0 !important;
  }
  .template-sufix-commerical .shopify-section.apps .grp-entangle-badge-title::before {
    color: var(--cp-forest) !important;
    content: "100% 5-star reviews";
    display: block;
    font-family: var(--cp-body);
    font-size: .88rem;
    font-weight: 800;
    letter-spacing: .08em;
    line-height: 1.25;
    text-transform: uppercase;
  }
  .template-sufix-commerical .shopify-section.apps .grp-entangle-badge-stars {
    transform: scale(.82);
    transform-origin: center;
  }
  .template-sufix-commerical .shopify-section.apps .grp-entangle-badge-logo {
    transform: scale(.72);
    transform-origin: center;
  }
  .template-sufix-commerical .shopify-section.apps .grp-main-hyper-link,
  .template-sufix-commerical .shopify-section.apps .grp-entangle-item-date,
  .template-sufix-commerical .shopify-section.apps .grp-entangle-item-body-review {
    color: rgba(40, 50, 41, .72) !important;
    font-family: var(--cp-body) !important;
  }
  .template-sufix-commerical .shopify-section.apps .grp-entangle-item-head-name,
  .template-sufix-commerical .shopify-section.apps .grp-main-hyper-link b,
  .template-sufix-commerical .shopify-section.apps .grp-main-hyper-link strong {
    color: var(--cp-ink) !important;
  }

  @media (max-width: 980px) {
    .cp-hero__grid, .cp-problem__grid, .cp-advantage__grid, .cp-materials__row, .cp-form-grid { grid-template-columns: 1fr; }
    .cp-pathways { grid-template-columns: 1fr; }
    .cp-pathway--large, .cp-pathway { min-height: 360px; }
    .cp-work-grid { grid-template-columns: 1fr 1fr; }
    .cp-timeline { grid-template-columns: 1fr; border-bottom: 0; }
    .cp-step { border-right: 0; border-bottom: 1px solid var(--cp-line); padding-right: 0; }
  }
  @media (max-width: 640px) {
    .cp-section { padding: clamp(2.8rem, 12vw, 4rem) 1rem; }
    .cp-hero { padding: 2.1rem 1rem 2.6rem; }
    .cp-hero__title { font-size: clamp(2.05rem, 9.4vw, 3rem); line-height: 1.02; letter-spacing: 0; }
    .cp-hero__text { margin-top: .95rem; font-size: 1rem; line-height: 1.58; }
    .cp-hero__media { aspect-ratio: 1 / .92; }
    .cp-proof-strip__grid { grid-template-columns: 1fr; }
    .cp-proof-strip__names li { width: 100%; box-sizing: border-box; }
    .cp-proof-projects { grid-template-columns: 1fr; }
    .cp-proof-project__media { aspect-ratio: 1.28 / .82; }
    .cp-hero__actions, .cp-btn { width: 100%; }
    .cp-pathway, .cp-pathway--large { min-height: 260px; }
    .cp-work-grid, .cp-bullets, .cp-form-section form { grid-template-columns: 1fr; }
    .cp-problem__item { grid-template-columns: 38px 1fr; }
  }
</style>

<div class="commercial-page-v2">
  <section class="cp-hero" aria-labelledby="commercial-hero-title">
    <div class="cp-hero__grid">
      <div class="cp-hero__copy">
        <p class="cp-kicker">{{ section.settings.hero_kicker }}</p>
        <h1 id="commercial-hero-title" class="cp-hero__title">{{ section.settings.hero_title }}</h1>
        <p class="cp-hero__text">{{ section.settings.hero_text }}</p>
        <div class="cp-hero__actions">
          <a class="cp-btn cp-btn--primary" href="{{ section.settings.hero_primary_link }}">{{ section.settings.hero_primary_label }}</a>
          <a class="cp-btn cp-btn--secondary" href="{{ section.settings.hero_secondary_link }}">{{ section.settings.hero_secondary_label }}</a>
        </div>
        <p class="cp-hero__trust">{{ section.settings.hero_trust }}</p>
      </div>
      <figure class="cp-hero__media">
        {%- if section.settings.hero_image != blank -%}
          <img class="cp-img" src="{{ section.settings.hero_image | image_url: width: 1600 }}" srcset="{{ section.settings.hero_image | image_url: width: 800 }} 800w, {{ section.settings.hero_image | image_url: width: 1400 }} 1400w, {{ section.settings.hero_image | image_url: width: 2200 }} 2200w" sizes="(min-width: 980px) 52vw, 100vw" alt="{{ section.settings.hero_image.alt | default: 'Commercial hospitality furniture made by Innate Furniture' | escape }}" loading="eager" fetchpriority="high">
        {%- endif -%}
      </figure>
    </div>
  </section>

  <section class="cp-proof-strip" aria-label="Selected hospitality and commercial proof">
    <div class="cp-proof-strip__grid">
      <div>
        <h2 class="cp-proof-strip__title">{{ section.settings.proof_title }}</h2>
        <p class="cp-proof-strip__text">{{ section.settings.proof_text }}</p>
      </div>
      <div>
        <ul class="cp-proof-strip__names" aria-label="Selected commercial clients and projects">
          {%- if section.settings.proof_client_1 != blank -%}<li>{{ section.settings.proof_client_1 }}</li>{%- endif -%}
          {%- if section.settings.proof_client_2 != blank -%}<li>{{ section.settings.proof_client_2 }}</li>{%- endif -%}
