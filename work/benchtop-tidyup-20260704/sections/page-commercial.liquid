      </div>
      {% form 'contact' %}
        {%- if form.posted_successfully? -%}
          <p class="cp-form-success">{{ section.settings.form_success_text }}</p>
        {%- else -%}
          {%- if form.errors -%}<div class="cp-form-errors">{{ form.errors | default_errors }}</div>{%- endif -%}
          <input type="hidden" name="contact[Subject]" value="{{ section.settings.form_subject }}">
          <input type="text" name="contact[name]" placeholder="{{ section.settings.form_name_placeholder }}" autocomplete="name" required>
          <input type="email" name="contact[email]" placeholder="{{ section.settings.form_email_placeholder }}" autocomplete="email" required>
          <input type="tel" name="contact[phone]" placeholder="{{ section.settings.form_phone_placeholder }}" autocomplete="tel">
          <input type="text" name="contact[Business or organisation]" placeholder="{{ section.settings.form_business_placeholder }}">
          <select name="contact[Project type]">
            <option value="">{{ section.settings.form_project_placeholder }}</option>
            <option>Hospitality</option>
            <option>Boardroom / workplace</option>
            <option>Fit-out / custom</option>
            <option>Outdoor</option>
            <option>Other</option>
          </select>
          <p class="cp-form-help">{{ section.settings.form_help_text }}</p>
          <textarea name="contact[body]" placeholder="{{ section.settings.form_brief_placeholder }}" rows="6"></textarea>
          <button type="submit">{{ section.settings.form_button_label }}</button>
        {%- endif -%}
      {% endform %}
    </div>
  </section>
</div>

<script>
  (function () {
    var attempts = 0;
    function moveReviews() {
      attempts += 1;
      var reviewSlot = document.querySelector('[data-commercial-reviews-slot]');
      var reviewSection = document.querySelector('.template-sufix-commerical .shopify-section.apps');
      if (reviewSlot && reviewSection && !reviewSlot.contains(reviewSection)) {
        reviewSlot.appendChild(reviewSection);
        return;
      }
      if (attempts < 20) {
        window.setTimeout(moveReviews, 250);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', moveReviews, { once: true });
    } else {
      moveReviews();
    }
  })();
</script>

