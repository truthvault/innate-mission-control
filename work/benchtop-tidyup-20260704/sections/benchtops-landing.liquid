{%- comment -%} healthscan-cache-bust-20260604 {%- endcomment -%}
<div class="bench-page bench-page--{{ section.id }}" data-bench-section data-section-id="{{ section.id }}">

  {%- comment -%} ── Configurator CTA ─────────────────────────────────────── {%- endcomment -%}
  {%- if section.settings.show_cta_block -%}
  <section class="bench-cta">
    <div class="bench-cta__inner">
      {%- if section.settings.cta_heading != blank -%}
        {%- assign cta_heading_clean = section.settings.cta_heading | replace: '<p>', '' | replace: '</p>', '' -%}
        <h2 class="bench-display bench-cta__heading">{{ cta_heading_clean }}</h2>
      {%- endif -%}

      {%- if section.settings.cta_sub != blank -%}
        <div class="bench-cta__sub">{{ section.settings.cta_sub }}</div>
      {%- endif -%}

      {%- if section.settings.cta_url != blank and section.settings.cta_label != blank -%}
        <p class="bench-cta__action">
          <a class="bench-cta__btn"
             href="{{ section.settings.cta_url }}"
             {% if section.settings.cta_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
            <span class="bench-cta__btn-label">{{ section.settings.cta_label | escape }}</span>
            <span class="bench-cta__btn-arrow" aria-hidden="true">→</span>
          </a>
        </p>
      {%- endif -%}

      {%- if section.settings.cta_caption != blank -%}
        <p class="bench-cta__caption">{{ section.settings.cta_caption | escape }}</p>
      {%- endif -%}
    </div>
  </section>
  {%- endif -%}

  {%- comment -%} ── Timber species — three editorial spreads ─────────────── {%- endcomment -%}
  {%- if section.settings.show_species_block -%}
  <section class="bench-species">
    {%- if section.settings.species_anchor_id != blank -%}
      <div id="{{ section.settings.species_anchor_id }}" class="bench-species__anchor" aria-hidden="true"></div>
    {%- endif -%}
    <header class="bench-species__head">
      <p class="bench-eyebrow">{{ section.settings.species_eyebrow | default: 'The timbers' | escape }}</p>
      {%- assign species_heading_clean = section.settings.species_heading | replace: '<p>', '' | replace: '</p>', '' -%}
      <h2 class="bench-display bench-species__heading">{{ species_heading_clean }}</h2>
      {%- if section.settings.species_subhead != blank -%}
        <div class="bench-species__sub">{{ section.settings.species_subhead }}</div>
      {%- endif -%}
    </header>

    <article class="bench-spread bench-spread--media-left">
      <figure class="bench-spread__media">
        {%- if section.settings.feature_asset_filename != blank -%}
          <img
            class="bench-spread__photo"
            src="{{ section.settings.feature_asset_filename | asset_url }}"
            alt="{{ section.settings.feature_photo_alt | escape }}"
            loading="lazy"
            decoding="async"
            width="2048"
            height="1024"
          />
        {%- else -%}
          <img
            class="bench-spread__photo"
            src="{{ section.settings.feature_photo_url }}"
            alt="{{ section.settings.feature_photo_alt | escape }}"
            loading="lazy"
            decoding="async"
            width="2048"
            height="1024"
          />
        {%- endif -%}
      </figure>
      <div class="bench-spread__body">
        <p class="bench-eyebrow">{{ section.settings.feature_origin | escape }}{%- if section.settings.feature_latin != blank %} · {{ section.settings.feature_latin | escape }}{%- endif -%}</p>
        {%- assign feature_name_clean = section.settings.feature_name | replace: '<p>', '' | replace: '</p>', '' -%}
        <h3 class="bench-display bench-spread__name">{{ feature_name_clean }}</h3>
        {%- if section.settings.feature_text != blank -%}
          <div class="bench-spread__text">{{ section.settings.feature_text }}</div>
        {%- endif -%}
        {%- if section.settings.feature_meta != blank -%}
          <p class="bench-spread__meta">{{ section.settings.feature_meta | escape }}</p>
        {%- endif -%}
      </div>
    </article>

    <article class="bench-spread bench-spread--media-right">
      <figure class="bench-spread__media">
        {%- if section.settings.support_a_asset_filename != blank -%}
          <img
            class="bench-spread__photo"
            src="{{ section.settings.support_a_asset_filename | asset_url }}"
            alt="{{ section.settings.support_a_photo_alt | escape }}"
            loading="lazy"
            decoding="async"
            width="2048"
            height="1024"
          />
        {%- else -%}
          <img
            class="bench-spread__photo"
            src="{{ section.settings.support_a_photo_url }}"
            alt="{{ section.settings.support_a_photo_alt | escape }}"
            loading="lazy"
            decoding="async"
            width="2048"
            height="1024"
          />
        {%- endif -%}
      </figure>
      <div class="bench-spread__body">
        <p class="bench-eyebrow">{{ section.settings.support_a_origin | escape }}{%- if section.settings.support_a_latin != blank %} · {{ section.settings.support_a_latin | escape }}{%- endif -%}</p>
        {%- assign support_a_name_clean = section.settings.support_a_name | replace: '<p>', '' | replace: '</p>', '' -%}
        <h3 class="bench-display bench-spread__name">{{ support_a_name_clean }}</h3>
        {%- if section.settings.support_a_text != blank -%}
          <div class="bench-spread__text">{{ section.settings.support_a_text }}</div>
        {%- endif -%}
        {%- if section.settings.support_a_meta != blank -%}
          <p class="bench-spread__meta">{{ section.settings.support_a_meta | escape }}</p>
        {%- endif -%}
      </div>
    </article>

    <article class="bench-spread bench-spread--media-left">
      <figure class="bench-spread__media">
        {%- if section.settings.support_b_asset_filename != blank -%}
          <img
            class="bench-spread__photo"
            src="{{ section.settings.support_b_asset_filename | asset_url }}"
            alt="{{ section.settings.support_b_photo_alt | escape }}"
            loading="lazy"
            decoding="async"
            width="2048"
            height="1024"
          />
        {%- else -%}
          <img
            class="bench-spread__photo"
            src="{{ section.settings.support_b_photo_url }}"
            alt="{{ section.settings.support_b_photo_alt | escape }}"
            loading="lazy"
            decoding="async"
            width="2048"
            height="1024"
          />
        {%- endif -%}
      </figure>
      <div class="bench-spread__body">
        <p class="bench-eyebrow">{{ section.settings.support_b_origin | escape }}{%- if section.settings.support_b_latin != blank %} · {{ section.settings.support_b_latin | escape }}{%- endif -%}</p>
        {%- assign support_b_name_clean = section.settings.support_b_name | replace: '<p>', '' | replace: '</p>', '' -%}
        <h3 class="bench-display bench-spread__name">{{ support_b_name_clean }}</h3>
        {%- if section.settings.support_b_text != blank -%}
          <div class="bench-spread__text">{{ section.settings.support_b_text }}</div>
        {%- endif -%}
        {%- if section.settings.support_b_meta != blank -%}
          <p class="bench-spread__meta">{{ section.settings.support_b_meta | escape }}</p>
        {%- endif -%}
      </div>
    </article>
  </section>
  {%- endif -%}

  {%- comment -%} ── How it works ─────────────────────────────────────────── {%- endcomment -%}
  {%- if section.settings.show_steps_block -%}
  <section class="bench-steps">
    <header class="bench-steps__head">
      <p class="bench-eyebrow">{{ section.settings.steps_eyebrow | default: 'How it works' | escape }}</p>
      {%- assign steps_heading_clean = section.settings.steps_heading | replace: '<p>', '' | replace: '</p>', '' -%}
      <h2 class="bench-display bench-steps__heading">{{ steps_heading_clean }}</h2>
    </header>
    <ol class="bench-steps__list">
      <li class="bench-steps__step">
        <span class="bench-steps__num" aria-hidden="true">01</span>
        <h3 class="bench-steps__title">{{ section.settings.step_one_title | escape }}</h3>
        {%- if section.settings.step_one_text != blank -%}
          <p class="bench-steps__text">{{ section.settings.step_one_text }}</p>
        {%- endif -%}
      </li>
      <li class="bench-steps__step">
        <span class="bench-steps__num" aria-hidden="true">02</span>
        <h3 class="bench-steps__title">{{ section.settings.step_two_title | escape }}</h3>
        {%- if section.settings.step_two_text != blank -%}
          <p class="bench-steps__text">{{ section.settings.step_two_text }}</p>
        {%- endif -%}
      </li>
      <li class="bench-steps__step">
        <span class="bench-steps__num" aria-hidden="true">03</span>
        <h3 class="bench-steps__title">{{ section.settings.step_three_title | escape }}</h3>
        {%- if section.settings.step_three_text != blank -%}
          <p class="bench-steps__text">{{ section.settings.step_three_text }}</p>
        {%- endif -%}
      </li>
    </ol>
  </section>
  {%- endif -%}

  {%- comment -%} ── Delivery band ────────────────────────────────────────── {%- endcomment -%}
  {%- if section.settings.show_band_block -%}
  <section class="bench-band">
    {%- assign band_line_clean = section.settings.band_line | replace: '<p>', '' | replace: '</p>', '' -%}
    <div class="bench-band__line">{{ band_line_clean }}</div>
  </section>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Benchtops landing",
  "class": "section-benchtops-landing",
  "settings": [
    {
      "type": "header",
      "content": "Visible sub-sections"
