    },
    {
      "type": "text",
      "id": "feature_photo_alt",
      "label": "Photo alt text",
      "default": "West Coast Rimu grain"
    },

    {
      "type": "header",
      "content": "Supporting timber A"
    },
    {
      "type": "text",
      "id": "support_a_asset_filename",
      "label": "Photo asset filename",
      "info": "Theme asset filename. When set, used in place of the Photo URL field below."
    },
    {
      "type": "text",
      "id": "support_a_origin",
      "label": "Origin",
      "default": "Northland"
    },
    {
      "type": "text",
      "id": "support_a_latin",
      "label": "Latin name",
      "default": "Podocarpus totara"
    },
    {
      "type": "richtext",
      "id": "support_a_name",
      "label": "Display name",
      "default": "<p><em>Tōtara</em></p>"
    },
    {
      "type": "richtext",
      "id": "support_a_text",
      "label": "Text",
      "default": "<p>Slow-grown native softwood, recovered as windfall stock from Northland. Takes thicker pieces than the others, with a quieter, more even grain. The timber for benchtops that want presence without busyness.</p>"
    },
    {
      "type": "text",
      "id": "support_a_meta",
      "label": "Meta line",
      "default": "Native softwood · up to 43 mm thick"
    },
    {
      "type": "text",
      "id": "support_a_photo_url",
      "label": "Photo URL",
      "default": "https://cdn.shopify.com/s/files/1/0307/3094/4571/files/totara-tabletop-topdown-website-normalized-v2-4096x2048-2026-06-08.jpg?v=1781043363"
    },
    {
      "type": "text",
      "id": "support_a_photo_alt",
      "label": "Photo alt text",
      "default": "Northland Tōtara grain"
    },

    {
      "type": "header",
      "content": "Supporting timber B"
    },
    {
      "type": "text",
      "id": "support_b_asset_filename",
