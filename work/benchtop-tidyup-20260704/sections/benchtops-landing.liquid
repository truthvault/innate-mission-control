      "type": "richtext",
      "id": "cta_heading",
      "label": "Heading",
      "default": "<p>Make it <em>yours</em>.</p>"
    },
    {
      "type": "richtext",
      "id": "cta_sub",
      "label": "Subhead",
      "default": "<p>Pick your timber, set your size, add cut-outs. Get your full price, freight and GST included, in minutes.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Open the configurator"
    },
    {
      "type": "text",
      "id": "cta_url",
      "label": "Button URL",
      "default": "https://innate-mission-control.vercel.app/"
    },
    {
      "type": "checkbox",
      "id": "cta_new_tab",
      "label": "Open in a new tab",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_caption",
      "label": "Caption below button",
      "default": "Opens in a new tab."
    },

    {
      "type": "header",
      "content": "Timber species"
    },
    {
      "type": "text",
      "id": "species_eyebrow",
      "label": "Eyebrow",
      "default": "The timbers"
    },
    {
      "type": "richtext",
      "id": "species_heading",
      "label": "Heading",
      "default": "<p>Three native woods,<br/><em>three different stories</em>.</p>"
    },
    {
      "type": "richtext",
      "id": "species_subhead",
      "label": "Subhead",
      "default": "<p>Each timber comes from a different part of Aotearoa, with its own grain, tone, and provenance. Pick the one that suits your space.</p>"
    },
    {
      "type": "text",
      "id": "species_anchor_id",
      "label": "Species block anchor ID",
      "info": "Optional. Renders <div id=\"...\"> at the top of this block so other links can scroll-to it."
    },

    {
      "type": "header",
      "content": "Feature timber"
    },
    {
      "type": "text",
      "id": "feature_asset_filename",
      "label": "Photo asset filename",
      "info": "Theme asset filename (e.g. \"Totara Pill Boardroom Table Country Bark.png\"). When set, used in place of the Photo URL field below."
    },
    {
      "type": "text",
      "id": "feature_origin",
      "label": "Origin",
      "default": "West Coast"
    },
    {
      "type": "text",
      "id": "feature_latin",
      "label": "Latin name",
      "default": "Dacrydium cupressinum"
    },
    {
      "type": "richtext",
      "id": "feature_name",
      "label": "Display name",
      "default": "<p><em>Rimu</em></p>"
    },
    {
      "type": "richtext",
      "id": "feature_text",
      "label": "Text",
      "default": "<p>Centuries-old native softwood from the West Coast of the South Island. Warm orange-brown tones, a fine grain that deepens with age, and the timber most kitchens come back to. The classic NZ furniture wood.</p>"
    },
    {
      "type": "text",
      "id": "feature_meta",
      "label": "Meta line",
      "default": "Native softwood · up to 33 mm thick"
