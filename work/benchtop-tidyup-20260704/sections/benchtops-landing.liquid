    {
      "type": "header",
      "content": "How it works"
    },
    {
      "type": "text",
      "id": "steps_eyebrow",
      "label": "Eyebrow",
      "default": "How it works"
    },
    {
      "type": "richtext",
      "id": "steps_heading",
      "label": "Heading",
      "default": "<p>Three steps from <em>idea</em> to delivery.</p>"
    },
    {
      "type": "text",
      "id": "step_one_title",
      "label": "Step 1 title",
      "default": "Configure"
    },
    {
      "type": "text",
      "id": "step_one_text",
      "label": "Step 1 text",
      "default": "Pick your timber, set your size, add cut-outs. The price updates as you go — freight and GST included."
