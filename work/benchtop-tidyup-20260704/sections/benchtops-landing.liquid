    },
    {
      "type": "text",
      "id": "support_b_origin",
      "label": "Origin",
      "default": "West Coast"
    },
    {
      "type": "text",
      "id": "support_b_latin",
      "label": "Latin name",
      "default": "Nothofagus fusca"
    },
    {
      "type": "richtext",
      "id": "support_b_name",
      "label": "Display name",
      "default": "<p><em>Beech</em></p>"
    },
    {
      "type": "richtext",
      "id": "support_b_text",
      "label": "Text",
      "default": "<p>Lighter-toned native hardwood from the West Coast. The cleanest of the three on grain — paler, more contemporary, with the structural pedigree of a hardwood. The choice when you want timber that reads modern.</p>"
