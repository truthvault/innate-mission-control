    {
      "type": "text",
      "id": "step_two_title",
      "label": "Step 2 title",
      "default": "Quote"
    },
    {
      "type": "text",
      "id": "step_two_text",
      "label": "Step 2 text",
      "default": "Send the quote to yourself or straight to us. We'll come back to talk it through."
    },
    {
      "type": "text",
      "id": "step_three_title",
      "label": "Step 3 title",
