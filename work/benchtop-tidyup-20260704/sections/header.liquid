{% comment %} Header navigation cache refresh: 2026-06-18T11:17Z. {% endcomment %}
{%- liquid
  assign index = 0
  assign index_mega = 0
  assign main_menu = linklists[section.settings.main_nav_linklist]
  assign side_menu = linklists[section.settings.side_nav_linklist]
-%}
{% unless side_menu.empty? %}
  <div class="nav side-nav" role="navigation" aria-label="Primary">
    <a tabindex="-1" aria-label="{{ 'general.navigation.header_label' | t }}">
      <i class="fc fc-hamburguer"></i>
      {% if section.settings.enable_side_nav_text %}
        <span>{{ 'general.navigation.header_label' | t }}</span>
      {% endif %}
    </a>
    <div class="inner">
      <a data-action="toggle-browse" class="close" tabindex="-1">
        <i class="fc fc-close"></i>
      </a>
      <div class="menu">
        <ul class="root">
        {% for link in side_menu.links %}
          {% if link.url contains '/collections/home-living' %}{% continue %}{% endif %}
          {% assign index = index | plus: 1 %}
          <li>
            {% if link.levels == 0 %}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {% else %}
              <a href="{{ link.url }}" class="plus js-no-transition" data-action="link-to-child-list" data-handle="{{ link.title | handleize }}" aria-controls="SideNavLabel-{{ link.title | handleize }}" aria-expanded="false"><span>{{ link.title }}</span></a>
              <ul class="{{ link.title | handleize }}" id="SideNavLabel-{{ link.title | handleize }}" role="list">
                {% for child_link in link.links %}
                  {% assign index = index | plus: 1 %}
                  <li>
                    {% if child_link.levels == 0 %}
                      <a href="{{ child_link.url }}" >{{ child_link.title }}</a>
                    {% else %}
                      <a href="{{ child_link.url }}" class="plus js-no-transition" data-action="link-to-child-list" data-handle="{{ child_link.title | handleize }}" aria-controls="SideNavLabel-{{ link.title | handleize }}" aria-expanded="false"><span>{{ child_link.title }}</span></a>
                      <ul class="{{ child_link.title | handleize }}" id="SideNavLabel-{{ child_link.title | handleize }}" role="list">
                        {% for grandson_link in child_link.links %}
                          {% assign index = index | plus: 1 %}
                          <li>
                            <a href="{{ grandson_link.url }}"><span>{{ grandson_link.title }}</span></a>
                          </li>
                        {% endfor %}
                      </ul>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
        {% if shop.customer_accounts_enabled %}
          {% if customer %}
            {% assign index = index | plus: 1 %}
            <li><a href="{{ routes.account_url }}"><span>{{ 'layout.side_nav.account' | t }}</span></a></li>
            {% assign index = index | plus: 1 %}
            <li><a href="{{ routes.account_logout_url }}"><span>{{ 'layout.side_nav.logout' | t }}</span></a></li>
          {% else %}
            {% assign index = index | plus: 1 %}
            <li><a href="{{ routes.account_login_url }}"><span>{{ 'layout.side_nav.signin' | t }}</span></a></li>
          {% endif %}
        {% endif %}
        </ul>
      </div>

      <div class="extra">
        {% if section.settings.show_social_icons %}
          {% render 'connect' %}
        {% endif %}
        {% render 'language-and-country-selectors', extended: true %}
      </div>
    </div>
  </div>
{% endunless %}

<style type="text/css">
  .section-header .header:not(.solid):not(.showing-megamenu) {
    --text-color: {{ section.settings.transparent_header_text_color }};
    {% if section.settings.transparent_header_text_color == "#FFFFFF" %}
      --disclosure-bg: transparent;
    {% else %}
      --disclosure-bg: #ffffff;
    {% endif %}
  }
  {% if template.name == 'index' and section.settings.enable_transparent_header %}
    @media (max-width: 960px){
      .main .layout .shopify-section:first-child .content {
        margin-top: 30px;
      }
    }
  {% endif %}

  @media (max-width: 749px){
    #shopify-section-{{ section.id }} .header .logo img{width:140px!important;height:auto;}
  }
</style>

<style type="text/css">
  #shopify-section-{{ section.id }} .ih-mhead{display:none;}
  @media (max-width: 749px){
    #shopify-section-{{ section.id }} .header{display:none!important;}
    #shopify-section-{{ section.id }} .ih-mhead{display:block;background:#fbf8f2;border-bottom:1px solid rgba(12,32,28,.12);position:relative;z-index:50;}
    #shopify-section-{{ section.id }} .ih-mhead [hidden]{display:none;}
    #shopify-section-{{ section.id }} .ih-mhead-bar{display:flex;align-items:center;gap:10px;padding:11px 14px;}
    #shopify-section-{{ section.id }} .ih-mhead-left{display:flex;align-items:center;gap:16px;flex:1 1 0;}
    #shopify-section-{{ section.id }} .ih-mhead-right{display:flex;align-items:center;gap:16px;flex:1 1 0;justify-content:flex-end;}
    #shopify-section-{{ section.id }} .ih-mhead-logo{flex:0 0 auto;line-height:0;}
    #shopify-section-{{ section.id }} .ih-mhead-logo img{height:34px;width:auto;display:inline-block;}
    #shopify-section-{{ section.id }} .ih-mhead-burger{display:inline-flex;align-items:center;gap:7px;background:none;border:0;padding:0;cursor:pointer;color:#163832;font:600 13px/1 "Maven Pro",sans-serif;letter-spacing:.02em;}
    #shopify-section-{{ section.id }} .ih-mhead-burger .fc{font-size:20px;}
    #shopify-section-{{ section.id }} .ih-mhead-ic{color:#163832;display:inline-flex;align-items:center;position:relative;text-decoration:none;}
    #shopify-section-{{ section.id }} .ih-mhead-ic .fc{font-size:19px;}
    #shopify-section-{{ section.id }} .ih-mhead-count{position:absolute;top:-7px;right:-9px;min-width:15px;height:15px;border-radius:999px;background:#163832;color:#fffaf3;font:600 10px/15px "Maven Pro",sans-serif;text-align:center;padding:0 3px;}
    #shopify-section-{{ section.id }} .ih-mhead-search{display:flex;align-items:center;gap:8px;padding:10px 14px;border-top:1px solid rgba(12,32,28,.08);background:#f7f2ea;}
    #shopify-section-{{ section.id }} .ih-mhead-search input{flex:1 1 auto;min-width:0;height:40px;border:1px solid rgba(12,32,28,.25);border-radius:3px;background:#fff;padding:0 12px;font:400 16px/1 "Maven Pro",sans-serif;color:#163832;}
    #shopify-section-{{ section.id }} .ih-mhead-search input:focus{outline:2px solid #163832;outline-offset:1px;}
    #shopify-section-{{ section.id }} .ih-mhead-search-go{flex:0 0 auto;height:38px;width:44px;border:0;border-radius:3px;background:#163832;color:#fffaf3;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;}
    #shopify-section-{{ section.id }} .ih-mhead-search-go .fc{font-size:18px;}
    #shopify-section-{{ section.id }} .ih-mhead-cats-row{display:flex;align-items:center;gap:14px;padding:9px 14px;border-top:1px solid rgba(12,32,28,.08);overflow-x:auto;-webkit-overflow-scrolling:touch;white-space:nowrap;scrollbar-width:none;}
    #shopify-section-{{ section.id }} .ih-mhead-cats-row::-webkit-scrollbar{display:none;}
    #shopify-section-{{ section.id }} .ih-mhead-cat{flex:0 0 auto;color:#163832;font:500 12.5px/1 "Maven Pro",sans-serif;letter-spacing:.01em;text-decoration:none;white-space:nowrap;}
    #shopify-section-{{ section.id }} .ih-mhead-more{flex:0 0 auto;display:inline-flex;align-items:center;gap:3px;background:none;border:0;padding:0;cursor:pointer;color:#9a4f35;font:500 12.5px/1 "Maven Pro",sans-serif;white-space:nowrap;}
    #shopify-section-{{ section.id }} .ih-mhead-more-panel{border-top:1px solid rgba(12,32,28,.08);background:#f7f2ea;}
    #shopify-section-{{ section.id }} .ih-mhead-more-panel a{display:block;padding:12px 16px;color:#163832;font:500 13px/1 "Maven Pro",sans-serif;text-decoration:none;border-top:1px solid rgba(12,32,28,.05);}
    #shopify-section-{{ section.id }} .ih-mhead-drawer{border-top:1px solid rgba(12,32,28,.08);background:#fbf8f2;}
    #shopify-section-{{ section.id }} .ih-mhead-drawer-nav{padding:4px 0 14px;}
    #shopify-section-{{ section.id }} .ih-mhead-d-top{display:block;padding:13px 16px;color:#0c201c;font:500 1.2rem/1 "Cormorant Garamond",Georgia,serif;text-decoration:none;}
    #shopify-section-{{ section.id }} .ih-mhead-d-child{display:block;padding:8px 16px 8px 30px;color:#3a463f;font:400 14px/1 "Maven Pro",sans-serif;text-decoration:none;}
  }
</style>

<div class="ih-mhead">
  <div class="ih-mhead-bar">
    <div class="ih-mhead-left">
      <button type="button" class="ih-mhead-burger" data-ih-menu-toggle aria-label="Open menu" aria-expanded="false"><i class="fc fc-hamburguer" aria-hidden="true"></i><span>Menu</span></button>
      <button type="button" class="ih-mhead-ic" data-ih-search-toggle aria-label="Search" aria-expanded="false"><i class="fc fc-search" aria-hidden="true"></i></button>
    </div>
    <a class="ih-mhead-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      {%- if settings.logo -%}<img src="{{ settings.logo | image_url: width: 320 }}" alt="{{ shop.name | escape }}">{%- else -%}<span>{{ shop.name }}</span>{%- endif -%}
    </a>
    <div class="ih-mhead-right">
      {%- if shop.customer_accounts_enabled and section.settings.enable_account -%}
        <a class="ih-mhead-ic" href="{{ routes.account_url }}" aria-label="Account"><i class="fc fc-user" aria-hidden="true"></i></a>
      {%- endif -%}
      <a class="ih-mhead-ic ih-mhead-cart" href="{{ routes.cart_url }}" aria-label="Cart"><i class="fc fc-cart" aria-hidden="true"></i>{%- if cart.item_count > 0 -%}<span class="ih-mhead-count">{{ cart.item_count }}</span>{%- endif -%}</a>
    </div>
  </div>
  <form class="ih-mhead-search" action="{{ routes.search_url }}" method="get" role="search" data-ih-search-panel hidden>
    <input type="search" name="q" placeholder="Search" aria-label="Search" autocomplete="off" data-ih-search-input>
    <button type="submit" class="ih-mhead-search-go" aria-label="Search"><i class="fc fc-search" aria-hidden="true"></i></button>
  </form>
  {%- if main_menu.links.size > 0 -%}
  <div class="ih-mhead-cats">
    <div class="ih-mhead-cats-row">
      {%- for link in main_menu.links limit: 4 -%}
        {%- if link.url contains '/collections/home-living' -%}{% continue %}{%- endif -%}
        <a class="ih-mhead-cat" href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
      {%- if main_menu.links.size > 4 -%}
        <button type="button" class="ih-mhead-more" data-ih-more-toggle aria-expanded="false">More <span aria-hidden="true">&rsaquo;</span></button>
      {%- endif -%}
    </div>
    {%- if main_menu.links.size > 4 -%}
    <div class="ih-mhead-more-panel" data-ih-more-panel hidden>
      {%- for link in main_menu.links offset: 4 -%}
        {%- if link.url contains '/collections/home-living' -%}{% continue %}{%- endif -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </div>
    {%- endif -%}
  </div>
  {%- endif -%}
  <div class="ih-mhead-drawer" data-ih-drawer hidden>
    <nav class="ih-mhead-drawer-nav" aria-label="Main menu">
      {%- for link in main_menu.links -%}
        {%- if link.url contains '/collections/home-living' -%}{% continue %}{%- endif -%}
        <a class="ih-mhead-d-top" href="{{ link.url }}">{{ link.title }}</a>
        {%- for child in link.links -%}
          <a class="ih-mhead-d-child" href="{{ child.url }}">{{ child.title }}</a>
        {%- endfor -%}
      {%- endfor -%}
    </nav>
  </div>
</div>

<script>
  (function(){
    var mh = document.querySelector('#shopify-section-{{ section.id }} .ih-mhead');
    if(!mh) return;
    var burger=mh.querySelector('[data-ih-menu-toggle]'), drawer=mh.querySelector('[data-ih-drawer]');
    var moreBtn=mh.querySelector('[data-ih-more-toggle]'), morePanel=mh.querySelector('[data-ih-more-panel]');
    var searchBtn=mh.querySelector('[data-ih-search-toggle]'), searchPanel=mh.querySelector('[data-ih-search-panel]'), searchInput=mh.querySelector('[data-ih-search-input]');
    var groups=[[burger,drawer],[moreBtn,morePanel],[searchBtn,searchPanel]];
    function shut(btn,panel){ if(panel&&!panel.hasAttribute('hidden')){ panel.setAttribute('hidden',''); if(btn) btn.setAttribute('aria-expanded','false'); } }
    function toggle(btn,panel,onOpen){ if(!btn||!panel) return; var willOpen=panel.hasAttribute('hidden'); groups.forEach(function(g){ if(g[1]!==panel) shut(g[0],g[1]); }); if(willOpen){ panel.removeAttribute('hidden'); btn.setAttribute('aria-expanded','true'); if(onOpen) onOpen(); } else { panel.setAttribute('hidden',''); btn.setAttribute('aria-expanded','false'); } }
    if(burger&&drawer) burger.addEventListener('click',function(){ toggle(burger,drawer); });
    if(moreBtn&&morePanel) moreBtn.addEventListener('click',function(){ toggle(moreBtn,morePanel); });
    if(searchBtn&&searchPanel) searchBtn.addEventListener('click',function(){ toggle(searchBtn,searchPanel,function(){ if(searchInput) searchInput.focus(); }); });
  })();
</script>

<div class="header {% if template.name == 'index' and section.settings.enable_transparent_header %}overlaying transparent{% endif %} {% if section.settings.enable_sticky_header %}sticky{% endif %} {% render 'content-classes' %}" data-section-id="{{ section.id }}" data-section-type="header">
  <div class="relative">
    <div class="bar">
      <div class="left">
        {% unless side_menu.empty? %}
          <a data-action="toggle-browse" tabindex="-1">
            <i class="fc fc-hamburguer"></i>
            {% if section.settings.enable_side_nav_text %}
              <span>{{ 'general.navigation.header_label' | t }}</span>
            {% endif %}
          </a>
        {% endunless %}
      </div>
      <div class="right">
        {% render 'language-and-country-selectors', extended: false %}
        {% if shop.customer_accounts_enabled and section.settings.enable_account %}
          {% if customer %}
            <a class="icon-user" href="{{ routes.account_url }}" aria-label="{{ 'layout.side_nav.account' | t }}">
              <i class="fc fc-user"></i>
            </a>
          {% else %}
            <a class="icon-user" href="{{ routes.account_login_url }}" aria-label="{{ 'layout.side_nav.signin' | t }}">
              <i class="fc fc-user"></i>
            </a>
          {% endif %}
        {% endif %}
        {% if section.settings.enable_search %}
          <a class="icon-search js-no-transition" href="{{ routes.search_url }}" data-action="toggle-search" aria-label="{{ 'general.search.title' | t }}">
            <i class="fc fc-search"></i>
          </a>
        {% endif %}
        {% if section.settings.enable_cart %}
          <a class="icon-cart {% if settings.cart_type == 'drawer' %}js-no-transition{% endif %}" href="{{ routes.cart_url }}" {% if settings.cart_type == 'drawer' %}data-action="toggle-cart"{% endif %} aria-label="{{ 'cart.general.section_title' | t }}">
            <i class="fc fc-cart"></i>
            <span class="circle cart-count {% if cart.item_count == 0 %}hidden-count{% endif %}">{{ cart.item_count }}</span>
          </a>
        {% endif %}
      </div>
      <div class="center">
        {% assign logo_fixed_width = settings.logo_max_width | divided_by: 2 %}
        {% if logo_fixed_width >= 75 %}
          <style type="text/css">
            .section-header .header.solid .fixed a.logo h1 img {
              width: {{ logo_fixed_width | at_least: 100 }}px;
            }
          </style>
        {% endif %}
        {% render 'logo' %}
      </div>
    </div>
    {% unless main_menu.empty? %}
      {%- liquid
      assign megas = ''
      for block in section.blocks
        unless forloop.first == true
          assign megas = megas | append: '::'
        endunless
        assign megas = megas | append: block.settings.name
      endfor
      assign megas = megas | split: '::'
      assign base_scale = settings.base_scale | divided_by: 100.0
      -%}
      <div class="nav main-nav {% if section.settings.show_main_menu_on_mobile %}show-on-mobile{% endif %} {{ section.settings.menu_font_weight }}" role="navigation">
        <style type="text/css">
          .section-header .header .nav ul li a {
            text-transform: {{ section.settings.menu_text_transform }};
            letter-spacing: {{ section.settings.menu_letter_spacing }}px;
            font-size: {{ section.settings.menu_font_size | times: base_scale }}px;
          }
          .section-header .header .nav ul li {
            line-height: {{ section.settings.menu_font_size | plus: 2 | times: base_scale }}px;
          }
        </style>
        <ul class="root" role="list" aria-label="Secondary">
          {% for link in main_menu.links %}
            {% if link.url contains '/collections/home-living' %}{% continue %}{% endif %}
            {% assign link_handle = link.title | handleize %}
            {% if link_handle == 'boardrooms' %}{% continue %}{% endif %}
            {% liquid
              assign index = index | plus: 1
              if megas contains link.title
                assign has_mega =  true
                if settings.color_body_bg == settings.color_section_bg
                  assign with_padding =  false
                elsif settings.header_expanded
                  assign with_padding =  false
                else
                  assign with_padding =  true
                endif
              else
                assign has_mega =  false
              endif
            %}
            <li {% if has_mega %}class="megamenu {% if with_padding %}with-padding{% endif %}" {{ section.blocks[index_mega].shopify_attributes }}{% assign index_mega = index_mega | plus: 1 %}{% endif %} >
              {% if link_handle == 'commercial' %}
                {% comment %} innate-commercial-nav-dropdown-20260512: visible commercial dropdown while preserving overview link {% endcomment %}
                <a href="{{ link.url }}" aria-expanded="false" class="plus {% if link.url == request.path %}active{% endif %}" data-action="link-to-child-list" data-handle="commercial"><span>{{ link.title }}</span></a>
                <ul class="tab commercial" role="list">
                  <div class="columns">
                    <li class="column"><a href="/pages/commercial-1"><span>Commercial overview</span></a></li>
                    <li class="column"><a href="/pages/boardroom-tables"><span>Boardroom tables</span></a></li>
                    <li class="column"><a href="/pages/hospitality-furniture"><span>Hospitality furniture</span></a></li>
                  </div>
                </ul>
              {% elsif link.levels == 0 %}
                <a href="{{ link.url }}" {% if link.url == request.path %}class="active"{% endif %}><span>{{ link.title }}</span></a>
              {% else %}
                <a href="{{ link.url }}" aria-expanded="false" class="plus {% if link.url == request.path %}active{% endif %}" data-action="link-to-child-list" data-handle="{{ link.title | handleize }}"><span>{{ link.title }}</span></a>
                <ul class="tab {{ link.title | handleize }}" role="list">
                  {% if has_mega %}
                    <div class="line"></div>
                  {% endif %}
                  <div class="columns">
                    {% for child_link in link.links %}
                      {% assign index = index | plus: 1 %}
                      <li class="column">
                        <a href="{{ child_link.url }}" ><span>{{ child_link.title }}</span></a>
                        {% if child_link.levels > 0 %}
                          <ul>
                            {% for grandson_link in child_link.links %}
                              {% assign index = index | plus: 1 %}
                              <li>
                                <a href="{{ grandson_link.url }}" ><span>{{ grandson_link.title }}</span></a>
                              </li>
                            {% endfor %}
                          </ul>
                        {% endif %}
                      </li>
                    {% endfor %}
                    {% liquid
                      if has_mega
                        for block in section.blocks
                          if block.settings.name == link.title
                            if block.settings['image-1'] != blank
                              render 'header-megamenu-image', block: block, index: 1
                            endif
                            if block.settings['image-2'] != blank
                              render 'header-megamenu-image', block: block, index: 2
                            endif
                            if block.settings['image-3'] != blank
                              render 'header-megamenu-image', block: block, index: 3
                            endif
                          endif
                        endfor
                      endif
                    %}
                  </div>
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endunless %}
    <div class="background"></div>
  </div>
</div>

{% if settings.cart_type == 'drawer' %}
  {% render 'side-cart' %}
{% endif %}
{% if section.settings.enable_search %}
  {% render 'search-overlay' %}
{% endif %}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {%- if section.settings.logo -%}
      "logo": {{ section.settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {%- endif -%}
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.header.settings.header__1.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.header.settings.paragraph__1.content"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__2.content"
    },
    {
      "type": "link_list",
      "id": "main_nav_linklist",
      "label": "t:sections.header.settings.main_nav_linklist.label",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_main_menu_on_mobile",
      "label": "t:sections.header.settings.show_main_menu_on_mobile.label",
      "default": false
    },
    {
      "type": "range",
      "id": "menu_font_size",
      "label": "t:sections.header.settings.menu_font_size.label",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "menu_letter_spacing",
      "label": "t:sections.header.settings.menu_letter_spacing.label",
      "min": 0,
      "max": 2,
      "step": 1,
      "default": 1,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "menu_text_transform",
      "label": "t:sections.header.settings.menu_text_transform.label",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:sections.header.settings.menu_text_transform.options__1"
        },
        {
          "value": "uppercase",
          "label": "t:sections.header.settings.menu_text_transform.options__2"
        },
        {
          "value": "lowercase",
          "label": "t:sections.header.settings.menu_text_transform.options__3"
        }
      ]
    },
    {
      "type": "select",
      "id": "menu_font_weight",
      "label": "t:sections.header.settings.menu_font_weight.label",
      "default": "normal",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.header.settings.menu_font_weight.options__1"
        },
        {
          "value": "bold",
          "label": "t:sections.header.settings.menu_font_weight.options__2"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__3.content"
    },
    {
      "type": "link_list",
      "id": "side_nav_linklist",
      "label": "t:sections.header.settings.side_nav_linklist.label",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "enable_side_nav_text",
      "label": "t:sections.header.settings.enable_side_nav_text.label",
      "info": "t:sections.header.settings.enable_side_nav_text.info",
