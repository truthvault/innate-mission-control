  assign hero_layout = section.settings.hero_layout | default: 'image_right'
  assign hero_primary_link = section.settings.hero_primary_link | default: '#atelier-builder'
  assign hero_secondary_link = section.settings.hero_secondary_link | default: '/products/product-sample'
  assign sample_link = section.settings.sample_link | default: '/products/product-sample'
