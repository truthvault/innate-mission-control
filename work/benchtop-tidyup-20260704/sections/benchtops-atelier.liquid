<script>
  (function () {
    var builderHash = '#atelier-builder';

    document.documentElement.classList.add('bench-atelier-template');

    if ('scrollRestoration' in window.history) {
      window.history.scrollRestoration = 'manual';
    }

    if (window.location.hash === builderHash && window.history && window.history.replaceState) {
      window.history.replaceState(null, '', window.location.pathname + window.location.search);
    }
  })();
</script>

{%- comment -%}
  innate-benchtop-texture-preload-20260628: start the timber textures downloading immediately
  instead of waiting for the configurator JS to request them (saves ~1s before the wood appears).
  URLs are kept bare (no ?v=) to match new URL(`benchtop-timber-...jpg`, import.meta.url) in
  innate-benchtop-configurator.js, so the preload is a cache hit rather than a second download.
{%- endcomment -%}
{%- liquid
  assign innate_species = 'rimu,totara,beech' | split: ','
  assign innate_colours = 'clear,bark,darkwash' | split: ','
-%}
{%- for sp in innate_species -%}
  {%- assign innate_hero = 'benchtop-timber-species-' | append: sp | append: '.jpg' | asset_url | split: '?' | first -%}
  <link rel="preload" as="image" href="{{ innate_hero }}" fetchpriority="high">
  {%- for col in innate_colours -%}
    {%- assign innate_sw = 'benchtop-timber-' | append: sp | append: '-' | append: col | append: '.jpg' | asset_url | split: '?' | first -%}
    <link rel="preload" as="image" href="{{ innate_sw }}">
  {%- endfor -%}
{%- endfor -%}

