  assign api_base = section.settings.api_base | default: 'https://innate-mission-control.vercel.app'
  assign asset_base = section.settings.asset_base | default: 'https://innate-mission-control.vercel.app'
-%}

<div class="bench-atelier bench-atelier--hero-{{ hero_layout | handle }}" data-section-id="{{ section.id }}">
  <section class="atelier-hero" aria-label="Custom timber benchtops NZ">
    <div class="atelier-hero__inner">
      <div class="atelier-hero__copy">
        <p class="atelier-kicker">{{ section.settings.hero_kicker | default: 'Custom timber benchtops NZ' | escape }}</p>
        <h1>{{ section.settings.hero_heading | default: 'Plan your timber benchtop. See the quote as you go.' | escape }}</h1>
        <p class="atelier-lead">{{ section.settings.hero_lead | default: 'For kitchen benchtops, shelves, vanities, laundries and other timber work surfaces. Choose your timber, set the size and see the quote as you go.' | escape }}</p>
        <div class="atelier-actions" aria-label="Benchtop actions">
          <a class="atelier-button atelier-button--primary innate-glass-primary-cta" href="{{ hero_primary_link }}">{{ section.settings.hero_primary_label | default: 'Start your benchtop brief' | escape }}</a>
          <a class="atelier-button atelier-button--secondary" href="{{ hero_secondary_link }}">{{ section.settings.hero_secondary_label | default: 'Order samples' | escape }}</a>
        </div>
      </div>

      {%- if section.settings.customer_install_image != blank -%}
        <figure class="atelier-hero__image">
          {{ section.settings.customer_install_image | image_url: width: 2400 | image_tag:
            alt: hero_alt,
            class: 'atelier-hero__photo',
            sizes: '(min-width: 990px) 46vw, 100vw',
            loading: 'eager',
            fetchpriority: 'high',
            width: section.settings.customer_install_image.width,
            height: section.settings.customer_install_image.height
          }}
        </figure>
      {%- elsif section.settings.customer_install_asset_filename != blank -%}
        <figure class="atelier-hero__image">
          <img
            src="{{ section.settings.customer_install_asset_filename | asset_url }}"
            alt="{{ hero_alt | escape }}"
            class="atelier-hero__photo"
            loading="eager"
            fetchpriority="high"
            width="958"
            height="1280"
          >
        </figure>
      {%- elsif section.settings.hero_image != blank -%}
        {%- capture hero_srcset -%}
          {%- assign widths = '720,1080,1440,1920,2400' | split: ',' -%}
          {%- for w in widths -%}
            {{ section.settings.hero_image | image_url: width: w }} {{ w }}w{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        {%- endcapture -%}
        <figure class="atelier-hero__image">
          {{ section.settings.hero_image | image_url: width: 2400 | image_tag:
            alt: hero_alt,
            class: 'atelier-hero__photo',
            sizes: '(min-width: 990px) 46vw, 100vw',
            srcset: hero_srcset,
            loading: 'eager',
            fetchpriority: 'high',
            width: section.settings.hero_image.width,
            height: section.settings.hero_image.height
          }}
        </figure>
      {%- endif -%}

    </div>
  
