/* Benchtop quote/share modal hardening — 2026-06-22
   Keeps every quote pop-up inside the viewport and makes form/success actions readable. */
.innate-bench-modal,
.innate-bench-modal *,
.innate-bench-modal *::before,
.innate-bench-modal *::after {
  box-sizing: border-box;
}

.innate-bench-modal {
  align-items: flex-start;
  justify-content: center;
  overflow-y: auto;
  padding: max(12px, env(safe-area-inset-top, 0px)) 12px max(12px, env(safe-area-inset-bottom, 0px));
}

.innate-bench-modal .modal__panel {
  margin: auto;
  max-height: calc(100dvh - 24px);
  max-width: min(1080px, calc(100vw - 24px));
  overflow-x: hidden;
  overflow-y: auto;
  overscroll-behavior: contain;
  width: 100%;
}

.innate-bench-modal--success .modal__panel {
  max-width: min(520px, calc(100vw - 24px));
}

.innate-bench-modal .modal__head {
  min-width: 0;
}

.innate-bench-modal .modal__head h2,
.innate-bench-modal .quote-summary,
.innate-bench-modal .share-path,
.innate-bench-modal .trust-strip,
.innate-bench-modal .quote-success,
.innate-bench-modal .quote-success p {
  min-width: 0;
  overflow-wrap: anywhere;
}

.innate-bench-modal .quote-form {
  gap: .72rem .75rem;
}

.innate-bench-modal .field {
  gap: .28rem;
  min-width: 0;
}

.innate-bench-modal .field span {
  line-height: 1.35;
}

.innate-bench-modal .field input,
.innate-bench-modal .field textarea {
  font-size: 16px;
  line-height: 1.35;
  min-height: 44px;
  padding: .64rem .72rem;
}

.innate-bench-modal .field--notes textarea {
  min-height: 78px;
}

.innate-bench-modal .quote-form__actions,
.innate-bench-modal .quote-success__actions {
  align-items: stretch;
  display: flex;
  flex-wrap: wrap;
  gap: .65rem;
  justify-content: flex-end;
  margin-top: .9rem;
  width: 100%;
}

.innate-bench-modal .quote-form__actions .btn-ghost,
.innate-bench-modal .quote-form__actions .btn-primary,
.innate-bench-modal .quote-success__actions .btn-ghost,
.innate-bench-modal .quote-success__actions .btn-primary,
.innate-bench-modal .quote-form__err .btn-ghost {
  align-items: center;
  display: inline-flex;
  justify-content: center;
  min-height: 44px;
  white-space: normal;
}

.innate-bench-modal .quote-form__actions .btn-ghost,
.innate-bench-modal .quote-success__actions .btn-ghost {
  border-color: var(--stone-200);
  background: var(--paper);
}

.innate-bench-modal .quote-form__err--send {
  align-items: flex-start;
  background: #fff7f5;
  border: 1px solid rgba(170, 69, 43, .28);
  border-radius: 8px;
  color: var(--danger);
  display: flex;
  flex-direction: column;
  gap: .55rem;
  line-height: 1.45;
  margin-top: .1rem;
  padding: .75rem .85rem;
}

.innate-bench-modal .quote-success {
  align-items: flex-start;
  padding: .4rem 0 .1rem;
  text-align: left;
}

.innate-bench-modal .quote-success__check {
  margin-bottom: .75rem;
}

.innate-bench-modal .quote-success__title {
  font-family: var(--atelier-serif, Georgia, serif);
  font-size: clamp(1.8rem, 8vw, 2.35rem);
  line-height: 1.05;
}

.innate-bench-modal .quote-success__body,
.innate-bench-modal .quote-success__note {
  max-width: none;
  width: 100%;
}

.innate-bench-modal .quote-success__body {
  color: var(--ink);
  font-size: 1rem;
  line-height: 1.55;
}

.innate-bench-modal .quote-success__note {
  font-size: .9rem !important;
  line-height: 1.5;
}

@media (min-width: 760px) {
  .innate-bench-modal--success .modal__panel {
    display: block;
    padding: 32px;
  }

  .innate-bench-modal--form .modal__panel,
  .innate-bench-modal--sending .modal__panel,
  .innate-bench-modal--error .modal__panel {
    grid-template-columns: minmax(260px, 300px) minmax(0, 1fr);
  }
}

@media (max-width: 759px) {
  .innate-bench-modal {
    padding: 10px 10px max(10px, env(safe-area-inset-bottom, 0px));
  }

  .innate-bench-modal .modal__panel {
    border-radius: 10px;
    max-height: calc(100dvh - 20px);
    max-width: calc(100vw - 20px);
    padding: 1rem;
  }

  .innate-bench-modal .modal__head {
    gap: .55rem;
    margin-bottom: .75rem;
  }

  .innate-bench-modal .modal__head h2 {
    font-size: clamp(1.35rem, 7vw, 1.85rem);
  }

  .innate-bench-modal .quote-summary {
    margin-bottom: .8rem;
    padding: .78rem .82rem;
  }

  .innate-bench-modal .quote-summary__total-amt {
    font-size: clamp(1.7rem, 10vw, 2.2rem);
  }

  .innate-bench-modal .share-paths {
    gap: .62rem;
  }

  .innate-bench-modal .share-path {
    min-height: 0;
    padding: .82rem .78rem;
  }

  .innate-bench-modal .share-path__sub,
  .innate-bench-modal .trust-strip p {
    font-size: .88rem;
  }

  .innate-bench-modal .quote-form {
    grid-template-columns: 1fr;
  }

  .innate-bench-modal .quote-form__actions,
  .innate-bench-modal .quote-success__actions {
    display: grid;
    grid-template-columns: 1fr;
  }

  .innate-bench-modal .quote-form__actions .btn-ghost,
  .innate-bench-modal .quote-form__actions .btn-primary,
  .innate-bench-modal .quote-success__actions .btn-ghost,
  .innate-bench-modal .quote-success__actions .btn-primary {
    width: 100%;
  }

  .innate-bench-modal .preference-group__details,
  .innate-bench-modal .contact-method {
    grid-template-columns: 1fr;
  }
}


/* Benchtop modal hardening follow-up: success panel and real mobile viewport cap. */
.innate-bench-modal .modal__panel:has(.quote-success) {
  display: block !important;
  max-width: min(520px, calc(100vw - 24px)) !important;
}

@media (max-width: 759px) {
  .innate-bench-modal .modal__panel {
    max-height: calc(100vh - 20px) !important;
  }
}


  
