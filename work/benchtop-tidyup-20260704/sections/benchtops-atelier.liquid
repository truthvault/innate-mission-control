<script>
  (function () {
    var builderHash = '#atelier-builder';
    var scrollTargetSelector = '.atelier-configurator-mount';

    function track(eventName, detail) {
      try {
        if (Array.isArray(window.dataLayer)) {
          window.dataLayer.push(Object.assign({ event: eventName }, detail || {}));
        }
      } catch (error) {
        /* Keep custom events available even if a tag manager is not present. */
      }

      try {
        document.dispatchEvent(new CustomEvent('innate:' + eventName, { detail: detail || {} }));
      } catch (error) {
        return;
      }
    }

    function scrollToBuilder() {
      var target = document.querySelector('[data-atelier-builder]') || document.querySelector('.atelier-builder');
      if (!target) return;
      var visualTarget = target.querySelector(scrollTargetSelector) || target;
      var offset = window.innerWidth < 760 ? 78 : 96;
      var y = visualTarget.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
    }

    function closeTimberPreview() {
      var preview = document.querySelector('.atelier-swatch-preview');
      if (preview) preview.remove();
      document.documentElement.classList.remove('atelier-swatch-preview-open');
    }

    function openTimberPreview(tile) {
      if (!tile) return;
      var image = tile.querySelector('img');
      if (!image) return;
      closeTimberPreview();

      var name = tile.querySelector('.timber-tile__name');
      var rate = tile.querySelector('.timber-tile__rate');
      var preview = document.createElement('div');
      preview.className = 'atelier-swatch-preview';
      preview.setAttribute('role', 'dialog');
      preview.setAttribute('aria-modal', 'true');
      preview.setAttribute('aria-label', 'Timber sample preview');
      preview.innerHTML =
        '<button class="atelier-swatch-preview__close" type="button" aria-label="Close timber preview">×</button>' +
        '<figure>' +
          '<img src="' + (image.currentSrc || image.src) + '" alt="' + (image.alt || 'Timber sample') + '">' +
          '<figcaption><strong>' + (name ? name.textContent : 'Timber sample') + '</strong>' +
          (rate ? '<span>' + rate.textContent + '</span>' : '') +
          '</figcaption>' +
        '</figure>';
      document.body.appendChild(preview);
      document.documentElement.classList.add('atelier-swatch-preview-open');
      preview.querySelector('.atelier-swatch-preview__close').focus({ preventScroll: true });
    }

    document.addEventListener('click', function (event) {
      var link = event.target && event.target.closest ? event.target.closest('a[href="' + builderHash + '"]') : null;
      if (link) {
        event.preventDefault();
        track('bench_start_quote', { source: link.textContent.trim() || 'builder_cta' });
        scrollToBuilder();
        return;
      }

      var sampleLink = event.target && event.target.closest ? event.target.closest('a[href*="/products/product-sample"]') : null;
      if (sampleLink) {
        track('bench_order_samples_click', { source: sampleLink.textContent.trim() || 'sample_link' });
        return;
      }

      var config = event.target && event.target.closest ? event.target.closest('#innate-benchtop-configurator') : null;
      if (!config) {
        var faqSummary = event.target && event.target.closest ? event.target.closest('.faq summary') : null;
        if (faqSummary) {
          var title = faqSummary.textContent.trim().replace(/\s+/g, ' ');
          track('bench_faq_open', { question: title });
        }
        return;
      }

      var swatchImage = event.target.closest('.timber-tile__photo, .timber-tile img');
      if (swatchImage) {
        closeTimberPreview();
      }

      if (event.target.closest('.timber-tile')) track('bench_change_timber');
      if (event.target.closest('.material-card__seg-btn, .stickybar__finish-btn')) track('bench_change_finish');
      if (event.target.closest('.panel-row__add, .panel-editor__add')) track('bench_add_panel');
      if (event.target.closest('.stickybar__cta, .stickybar__price--btn')) track('bench_share_quote_start');
    }, true);

    document.addEventListener('click', function (event) {
      if (!event.target || !event.target.closest) return;
      if (event.target.matches('.atelier-swatch-preview') || event.target.closest('.atelier-swatch-preview__close')) {
        closeTimberPreview();
      }
    });

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') closeTimberPreview();
    });

    document.addEventListener('change', function (event) {
      if (!event.target || !event.target.closest) return;
      if (event.target.closest('#innate-benchtop-configurator .panel-row')) {
        track('bench_change_dimensions');
      }
      if (event.target.closest('#innate-benchtop-configurator .addr-search')) {
        track('bench_delivery_address_entered');
      }
    }, true);

    function updateBuilderStickyState() {
      var builder = document.querySelector('[data-atelier-builder]') || document.querySelector('.atelier-builder');
      var footer = document.querySelector('.shopify-section-group-footer-group') || document.querySelector('footer');
      if (!builder) return;
      var rect = builder.getBoundingClientRect();
      var footerRect = footer ? footer.getBoundingClientRect() : null;
      var narrow = window.innerWidth < 960;
      var active = narrow
        ? rect.top < (window.innerHeight * 0.68) && rect.bottom > (window.innerHeight * 0.46)
        : rect.top < (window.innerHeight * 0.82) && rect.bottom > 120;
      var finalCta = document.querySelector('.atelier-final-cta');
      var finalCtaRect = finalCta ? finalCta.getBoundingClientRect() : null;
      var footerActive = footerRect ? footerRect.top < (window.innerHeight - 120) : false;
      if (finalCtaRect && finalCtaRect.top < (window.innerHeight - 80)) footerActive = true;
      document.body.classList.toggle('bench-builder-ready', active);
      document.body.classList.toggle('bench-builder-footer', footerActive);
    }

    updateBuilderStickyState();
    window.addEventListener('scroll', updateBuilderStickyState, { passive: true });
    window.addEventListener('resize', updateBuilderStickyState);
    document.addEventListener('click', function (event) {
      var modeButton = event.target && event.target.closest ? event.target.closest('.mobile-mode-rail button, .mobile-piece-tab, .mobile-dim-chip') : null;
      if (!modeButton) return;
      window.setTimeout(function () {
        updateBuilderStickyState();
        var builder = document.querySelector('[data-atelier-builder]') || document.querySelector('.atelier-builder');
        if (!builder || window.innerWidth > 959) return;
        var y = builder.getBoundingClientRect().top + window.pageYOffset - 72;
        if (window.pageYOffset > y + 180 || window.pageYOffset < y - 120) {
          window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
        }
      }, 80);
    }, true);

  })();
</script>
