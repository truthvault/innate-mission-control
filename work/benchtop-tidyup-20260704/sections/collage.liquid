<div class="content collage desktop-{{ section.settings.desktop_layout }} mobile-{{ section.settings.mobile_layout }} {% render 'content-classes', scope: section %}" data-section-id="{{ section.id }}" data-section-type="collage">
  {% if section.settings.heading != blank %}
    <div class="rte">
      <p class="category">{{ section.settings.heading }}</p>
    </div>
  {% endif %}
  {% if section.blocks.size > 0 %}
    <div class="cards" style="max-width: {{ section.settings.content_max_width }}px;">
      {%- for block in section.blocks -%}
        {% liquid
          assign focus_card_left = false
          if section.settings.desktop_layout == 'left' and forloop.first
            assign focus_card_left = true
          elsif section.settings.desktop_layout == 'right' and forloop.last
            assign focus_card_right = true
          endif
          assign sizes = "34vw"
          assign media_scale = 0.34
          if forloop.length == 1
            assign sizes = "100vw"
            assign media_scale = 1.0
          elsif focus_card_left or focus_card_right
            assign sizes = "67vw"
            assign media_scale = 0.67
          endif
          assign max_image_width = section.settings.content_max_width | times: media_scale | round
          assign sizes = "min("| append: sizes | append: ", " | append: max_image_width | append: "px)"
          if section.settings.mobile_layout == 'column'
            assign sizes = "(max-width: 620px) 100vw, " | append: sizes
          endif
        %}
        <div class="card {% if block.settings.show_border %} show-border{% endif %}{% if focus_card_left %} card-left{% elsif focus_card_right %} card-right{% endif %}" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'image' -%}
              {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
              {%- if block.settings.image != blank -%}
                {% render 'resp-img', image: block.settings.image, sizes: sizes %}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="card-info {{ block.settings.text_align }}">{{ block.settings.text }}</div>
              {%- endif -%}
              {%- if block.settings.link != blank -%}</a>{%- endif -%}

            {%- when 'product'-%}
              {% liquid 
                capture collection_products_classes
                  render 'get-collection-products-classes'
                endcapture
                assign collection_products_classes = collection_products_classes | remove: "with-interactions"
              %}

              <div class="collection-products no-columns {{ collection_products_classes }}">
                {% liquid
                  if block.settings.product != blank
                    render 'collection-product', product: block.settings.product, sizes: sizes, image_ratio: 'adapt'
                  else
                    render 'dummie-collection-product', index: forloop.index
                  endif
                %}
              </div>
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  {% else %}
    {% render 'no-blocks' %}
  {% endif %}
</div>

{% schema %}
{
  "name": "t:sections.collage.name",
  "class": "section-collage",
  "settings": [
    {
      "type": "select",
      "id": "desktop_layout",
      "options": [
        {
          "value": "left",
          "label": "t:sections.collage.settings.desktop_layout.options__1.label"
        },
        {
          "value": "right",
          "label": "t:sections.collage.settings.desktop_layout.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.collage.settings.desktop_layout.label"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "options": [
        {
          "value": "collage",
          "label": "t:sections.collage.settings.mobile_layout.options__1.label"
        },
        {
          "value": "column",
          "label": "t:sections.collage.settings.mobile_layout.options__2.label"
        }
      ],
      "default": "collage",
      "label": "t:sections.collage.settings.mobile_layout.label"
    },
    {
      "type": "header",
      "content": "t:sections.settings.header.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.settings.heading.label",
      "info": "t:sections.settings.heading.info"
    },
    {
      "type": "checkbox",
      "id": "show_background",
      "label": "t:sections.settings.show_background.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "expanded",
      "label": "t:sections.settings.expanded.label",
      "default": true
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "t:sections.settings.content_max_width.label",
      "default": 900,
      "min": 400,
      "max": 2000,
      "step": 50,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "expanded_content",
      "label": "t:sections.settings.expanded_content.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "collapsed",
      "label": "t:sections.settings.collapsed.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "t:sections.settings.show_on_desktop.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "t:sections.settings.show_on_mobile.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.collage.blocks.image.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.collage.blocks.image.settings.image.label"
        },
        {
          "type": "checkbox",
          "id": "show_border",
          "label": "t:sections.collage.blocks.block.settings.show_border.label",
          "default": false
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.collage.blocks.image.settings.link.label",
          "info": "t:sections.collage.blocks.image.settings.link.info"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.collage.blocks.image.settings.text.label",
          "info": "t:sections.collage.blocks.image.settings.text.info"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "t:sections.collage.blocks.image.settings.text_align.label",
          "default": "center",
          "options": [
            {
              "value": "left",
              "label": "t:sections.collage.blocks.image.settings.text_align.left.label"
            },
            {
              "value": "center",
              "label": "t:sections.collage.blocks.image.settings.text_align.center.label"
            },
            {
              "value": "right",
              "label": "t:sections.collage.blocks.image.settings.text_align.right.label"
            }
          ]
        }
      ]
    },
    {
      "type": "product",
      "name": "t:sections.collage.blocks.product.name",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:sections.collage.blocks.product.settings.product.label"
        },
        {
          "type": "checkbox",
          "id": "show_border",
          "label": "t:sections.collage.blocks.block.settings.show_border.label",
          "default": false
        },
        {
          "type": "header",
          "content": "t:sections.main-collection.settings.header__3.content"
        },
        {
          "type": "paragraph",
          "content": "t:sections.main-collection.settings.paragraph.content"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "t:sections.collage.presets.name",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}