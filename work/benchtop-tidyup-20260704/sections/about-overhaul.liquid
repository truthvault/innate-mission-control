    { "type": "text", "id": "people_heading", "label": "Heading" },
    { "type": "richtext", "id": "people_text", "label": "Text" },
    { "type": "header", "content": "Reviews" },
    { "type": "text", "id": "reviews_eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "reviews_heading", "label": "Heading" },
    { "type": "richtext", "id": "reviews_text", "label": "Text" },
    { "type": "header", "content": "Closing" },
    { "type": "text", "id": "closing_eyebrow", "label": "Eyebrow" },
