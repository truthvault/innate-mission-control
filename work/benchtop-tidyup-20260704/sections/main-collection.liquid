<div class="content collection featured-collection {% render 'content-classes', scope: section %}" data-section-id="{{ section.id }}" data-section-type="collection">
  {%- comment -%}Build dining block HTML in section scope so Shopify editor blocks render reliably inside the collection snippet.{%- endcomment -%}
  {% capture dining_shape_cards_html %}
{%- for block in section.blocks -%}
                {%- if block.type == 'dining_shape' -%}
                  {%- assign shape_type = block.settings.shape_type | default: 'rectangle' -%}
                  {%- assign shape_image = 'innate-rimu-tabletop-rectangle.webp' -%}
                  {%- case shape_type -%}
                    {%- when 'round' -%}{%- assign shape_image = 'innate-rimu-tabletop-circle.webp' -%}
                    {%- when 'pebble' -%}{%- assign shape_image = 'innate-rimu-tabletop-pebble.webp' -%}
                    {%- when 'danish' -%}{%- assign shape_image = 'innate-rimu-tabletop-danish.webp' -%}
                    {%- when 'pill' -%}{%- assign shape_image = 'innate-rimu-tabletop-pill.webp' -%}
                  {%- endcase -%}
                  <article class="d16-shape" {{ block.shopify_attributes }}><div><div class="d16-shape-art d16-shape-art--{{ shape_type }}">
                    <img class="d16-shape-img" src="{{ shape_image | asset_url }}" alt="{{ block.settings.title | default: 'Tabletop shape' | escape }} tabletop shape" width="900" height="437" loading="lazy" decoding="async">
                  </div><h3>{{ block.settings.title | default: 'Tabletop shape' }}</h3><p>{{ block.settings.text | default: 'Add a short note for this shape.' }}</p></div></article>
                {%- endif -%}
              {%- endfor -%}
              {% endcapture %}

  {% capture dining_detail_accordion_html %}
{%- for block in section.blocks -%}
                {%- if block.type == 'dining_detail' -%}
                  <details {{ block.shopify_attributes }}><summary>{{ block.settings.summary | default: 'Detail' }}</summary><div class="d16-detail-body">{{ block.settings.body }}</div></details>
                {%- endif -%}
              {%- endfor -%}
              {% endcapture %}

  {% render 'collection', collection: collection, section_settings: section.settings, dining_shape_cards_html: dining_shape_cards_html, dining_detail_accordion_html: dining_detail_accordion_html %}
  <script>
    (function(){
      function fixDiningContactFormEncoding(){
        var form = document.querySelector('#dining-contact-form form');
        if (form && form.getAttribute('enctype') === 'multipart/form-data') form.removeAttribute('enctype');
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', fixDiningContactFormEncoding);
      else fixDiningContactFormEncoding();
      window.addEventListener('load', fixDiningContactFormEncoding);
      document.addEventListener('submit', function(event){
        if (event.target && event.target.matches && event.target.matches('#dining-contact-form form')) fixDiningContactFormEncoding();
      }, true);
    })();
  </script>
</div>

