<div class="innate-dining-v16 innate-dining-v16--after-products" data-dining-editor-section="enquiry">
  <section class="d16-cta" id="dining-enquiry" aria-label="{{ section.settings.aria_label | escape }}">
    <div class="d16-wrap">
      <div class="d16-cta-grid">
        <div>
          {%- if section.settings.eyebrow != blank -%}<p class="d16-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
          <h2 class="d16-display">{{ section.settings.heading }}</h2>
          {%- if section.settings.text != blank -%}<p class="d16-copy">{{ section.settings.text }}</p>{%- endif -%}
        </div>
        <div>
          <div class="d16-enquiry-form-wrap" id="dining-contact-form">
            {% form 'contact', class: 'd16-enquiry-form', return_to: '/collections/dining-tables?contact_posted=true#dining-contact-form' %}
              <div class="d36-form-head">
                <h3>{{ section.settings.form_heading }}</h3>
                {%- if section.settings.form_intro != blank -%}<p class="d31-form-intro">{{ section.settings.form_intro }}</p>{%- endif -%}
              </div>
              {% if form.posted_successfully? %}
                <div class="d29-form-success" role="status" aria-live="polite"><strong>{{ section.settings.success_heading }}</strong><span>{{ section.settings.success_text }}</span></div>
              {% endif %}
              {% if form.errors %}
                <div class="d29-form-error" role="alert"><strong>{{ section.settings.error_heading }}</strong>{{ form.errors | default_errors }}</div>
              {% endif %}
              <div class="d29-form-success" data-d29-url-success hidden role="status" aria-live="polite"><strong>{{ section.settings.success_heading }}</strong><span>{{ section.settings.success_text }}</span></div>
              <input type="hidden" name="contact[Enquiry type]" value="{{ section.settings.enquiry_type }}">
              <div class="d16-form-grid">
                <div class="d16-field"><label for="DiningContactName">{{ section.settings.name_label }}</label><input id="DiningContactName" type="text" name="contact[name]" autocomplete="name" required></div>
                <div class="d16-field"><label for="DiningContactEmail">{{ section.settings.email_label }}</label><input id="DiningContactEmail" type="email" name="contact[email]" autocomplete="email" required></div>
                <div class="d16-field"><label for="DiningContactPhone">{{ section.settings.phone_label }}</label><input id="DiningContactPhone" type="tel" name="contact[phone]" autocomplete="tel"></div>
              </div>
              <div class="d16-field d16-field--message">
                <label for="DiningContactMessage">{{ section.settings.message_label }}</label>
                {%- if section.settings.message_help != blank -%}<p class="d36-field-help">{{ section.settings.message_help }}</p>{%- endif -%}
                <textarea id="DiningContactMessage" name="contact[body]" rows="7" required placeholder="{{ section.settings.message_placeholder | escape }}"></textarea>
              </div>
              <button type="submit" class="d16-btn">{{ section.settings.button_label }}</button>
              {%- if section.settings.submit_note != blank -%}<p class="d36-submit-note">{{ section.settings.submit_note }}</p>{%- endif -%}
            {% endform %}
          </div>
        </div>
      </div>
      <div class="d16-contact-cards" aria-label="{{ section.settings.cards_aria_label | escape }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'contact_card' -%}
            <a class="d16-contact-card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}><strong>{{ block.settings.heading }}</strong><span>{{ block.settings.text }}</span>{% if block.settings.detail != blank %}<span class="{{ block.settings.detail_class }}">{{ block.settings.detail }}</span>{% endif %}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
</div>
<script>
  (function(){
    if (!window.location.search || window.location.search.indexOf('contact_posted=true') === -1) return;
    function showDiningSuccess(){
      var formWrap = document.getElementById('dining-contact-form');
      var panel = document.querySelector('[data-d29-url-success]');
      if (panel) panel.hidden = false;
      var form = formWrap ? formWrap.querySelector('form') : null;
      if (form) form.classList.add('d29-submitted');
      if (formWrap) formWrap.scrollIntoView({ behavior:'smooth', block:'start' });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', showDiningSuccess); else showDiningSuccess();
  })();
</script>

{% schema %}
{
  "name": "Dining enquiry",
  "settings": [
    {"type":"text","id":"aria_label","label":"Section accessibility label","default":"Dining table enquiry"},
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Made to order"},
    {"type":"text","id":"heading","label":"Heading","default":"Start with what you know"},
    {"type":"textarea","id":"text","label":"Text","default":"You don’t need a finished spec. Send the rough direction and we’ll help narrow the size, timber, colour, shape and base."},
    {"type":"text","id":"form_heading","label":"Form heading","default":"Start with what you know"},
    {"type":"textarea","id":"form_intro","label":"Form intro","default":"A rough direction is enough — we’ll help narrow the size, timber, shape and base."},
    {"type":"text","id":"success_heading","label":"Success heading","default":"Thanks, your enquiry has been sent."},
    {"type":"textarea","id":"success_text","label":"Success text","default":"We’ll come back to you soon. If you have room or inspiration photos, reply to our email with 1–3 images."},
    {"type":"text","id":"error_heading","label":"Error heading","default":"Please check the details below."},
    {"type":"text","id":"enquiry_type","label":"Hidden enquiry type","default":"Custom dining table enquiry"},
    {"type":"text","id":"name_label","label":"Name field label","default":"Name"},
    {"type":"text","id":"email_label","label":"Email field label","default":"Email"},
    {"type":"text","id":"phone_label","label":"Phone field label","default":"Phone"},
    {"type":"text","id":"message_label","label":"Message field label","default":"Rough table brief"},
    {"type":"textarea","id":"message_help","label":"Message help text","default":"A rough note is plenty. Size, seating, timber, shape, room feel, or a table you’ve seen — whatever you’ve got."},
    {"type":"textarea","id":"message_placeholder","label":"Message placeholder","default":"Tell us what you know so far — even if it’s rough. For example: Crossroads style, about 2200 long, seats 6–8, probably tōtara, not sure on colour."},
    {"type":"text","id":"button_label","label":"Submit button label","default":"Send enquiry"},
    {"type":"textarea","id":"submit_note","label":"Submit note","default":"We’ll read it and come back with sensible next steps."},
    {"type":"text","id":"cards_aria_label","label":"Contact cards accessibility label","default":"Other ways to start"}
  ],
  "blocks": [
    {"type":"contact_card","name":"Contact card","settings":[
      {"type":"text","id":"heading","label":"Heading","default":"Call us"},
      {"type":"textarea","id":"text","label":"Text","default":"Quick questions about size, timber or lead times."},
      {"type":"text","id":"detail","label":"Detail text","default":"027 350 2083"},
      {"type":"select","id":"detail_class","label":"Detail style","default":"d18-phone","options":[{"value":"d18-phone","label":"Phone"},{"value":"d57-card-action","label":"Action"}]},
      {"type":"text","id":"link","label":"Link","default":"tel:+642****2083"}
    ]}
  ],
  "presets": [{"name":"Dining enquiry"}]
}
{% endschema %}
