{
  "name": "innate-mission-control",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:mutations": "bash scripts/check-no-monday-mutations.sh",
    "check:tuesday-page-contracts": "node scripts/check-tuesday-page-contracts.mjs",
    "smoke:tuesday": "node scripts/smoke-tuesday.mjs",
    "verify:tuesday-review-link": "node scripts/verify-tuesday-review-link.mjs",
    "audit:tuesday-visual": "node scripts/audit-tuesday-visual-consistency.mjs",
    "audit:tuesday-mobile": "node scripts/audit-tuesday-ui.mjs --profile=mobile",
    "audit:tuesday-desktop": "node scripts/audit-tuesday-ui.mjs --profile=desktop",
    "audit:tuesday-interactions": "node scripts/audit-tuesday-ui.mjs --profile=interactions",
    "audit:nick-readiness": "node scripts/audit-nick-readiness.mjs",
    "test:workshop-handoff": "node scripts/test-workshop-handoff-health.mjs && node scripts/test-invoice-expectation.mjs",
    "smoke:freight": "node scripts/smoke-freight.mjs",
    "test:planning:new-order": "node scripts/test-new-order-planning.mjs",
    "test:planning:colours": "node scripts/test-plan-new-order-colours.mjs",
    "test:planning:drag": "node scripts/test-plan-drag-stress.mjs",
    "test:planning:stage-suggestions": "node scripts/test-plan-task-stage-suggestions.mjs",
    "test:planning:nick-feedback": "node scripts/test-plan-nick-feedback.mjs",
    "test:planning:orders-all-active": "node scripts/test-plan-orders-all-active.mjs",
    "test:planning:order-priority": "node scripts/test-plan-order-priority-persistence.mjs",
    "test:planning:mobile-compact": "node scripts/test-plan-mobile-compact-chrome.mjs",
    "test:tuesday-mobile-ux-loop": "node scripts/test-tuesday-mobile-ux-loop.mjs",
    "test:planning": "npm run test:planning:new-order && npm run test:planning:colours && npm run test:planning:drag && npm run test:planning:stage-suggestions && npm run test:planning:nick-feedback && npm run test:planning:orders-all-active && npm run test:planning:order-priority && npm run test:planning:mobile-compact",
    "test:order-intake": "node scripts/test-order-intake-api.mjs && python3 scripts/test-akahu-order-payments.py",
    "reconcile:order-intake": "node scripts/reconcile-order-intake.mjs && python3 scripts/sync-akahu-order-payments.py --refresh && node scripts/reconcile-order-intake.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/blob": "^2.3.3",
    "airtable": "^0.12.2",
    "next": "^16.2.6",
    "playwright": "^1.60.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
