# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-deployment-id
/.next-static-archive/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.secrets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local agent/session artifacts
/.hermes/
/backups/
/data/

# generated/cache
__pycache__/
scripts/__pycache__/
*.pyc

# throwaway scripts
/tmp_*.py
/tmp_*.js
/tmp_*.mjs
/scripts/tmp_*

# website/archive working folders
/seo/

# local generated evidence and agent artifacts
/reports/
/artifacts/
/captures/
/screenshots/

# local tool dependency/install folders, source scripts stay reviewed separately
/tools/content-recording/node_modules/
/tools/content-recording/test-results/
/tools/content-recording/.playwright/
